---
import Font from "astro/components/Font.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import VideoLightbox from "../components/video/VideoLightbox.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import { getFirmDetails } from "../sanity/lib/firmDetails";
import { urlFor } from "../sanity/lib/image";
import { resolveSeo, SITE_NAME, type SeoInput } from "../lib/seo";
import { legalServiceSchema } from "../lib/schema";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** The page's Sanity `seo` block. Every field optional; blank → title/description above. */
  seo?: SeoInput | null;
  videoEmbed?: boolean; // pages with a Wistia video → warm up the connections
}

const { title, description, seo, videoEmbed = false } = Astro.props;

const firm = await getFirmDetails();

const meta = resolveSeo(seo, {
  fallbackTitle: title,
  fallbackDescription: description,
  pageUrl: Astro.url,
  defaultOgImage: firm?.defaultOgImage,
});

// `Astro.site` is set in astro.config.mjs; the fallback keeps a bare `astro dev`
// (which can run without it) from throwing on a template literal.
const siteUrl = (Astro.site?.href ?? "https://www.cogdell-law.com/").replace(/\/+$/, "");
const logoUrl = firm?.logo ? urlFor(firm.logo).width(600).auto("format").url() : undefined;
const organization = legalServiceSchema(firm, siteUrl, logoUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    {/* Flag JS up front so the lazy-image fade only hides images when it can un-hide them. */}
    <script is:inline>document.documentElement.classList.add("js");</script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {
      videoEmbed && (
        <Fragment>
          {/* DNS-only warm-up (cheap; no eager TLS competing with page load).
              The lightbox loads the Wistia player on click. */}
          <link rel="dns-prefetch" href="https://fast.wistia.net" />
          <link rel="dns-prefetch" href="https://embed-ssl.wistia.com" />
          <link rel="dns-prefetch" href="https://fast.wistia.com" />
          <link rel="dns-prefetch" href="https://distillery.wistia.com" />
        </Fragment>
      )
    }
    <Font cssVariable="--font-cormorant" preload />
    <Font cssVariable="--font-instrument" preload />
    <title>{meta.title}</title>
    {meta.description && <meta name="description" content={meta.description} />}
    <link rel="canonical" href={meta.canonical} />
    {meta.noIndex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={meta.title} />
    {meta.description && <meta property="og:description" content={meta.description} />}
    <meta property="og:url" content={meta.canonical} />
    {meta.ogImage && <meta property="og:image" content={meta.ogImage} />}

    <meta name="twitter:card" content={meta.ogImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={meta.title} />
    {meta.description && <meta name="twitter:description" content={meta.description} />}
    {meta.ogImage && <meta name="twitter:image" content={meta.ogImage} />}

    {organization && <JsonLd data={organization} />}
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <VideoLightbox />
    <script>
      // Fade each lazy image in once it decodes (covers the already-cached case).
      document
        .querySelectorAll<HTMLImageElement>("img.lazy-fade")
        .forEach((img) => {
          if (img.complete) {
            img.classList.add("is-loaded");
          } else {
            img.addEventListener("load", () => img.classList.add("is-loaded"), {
              once: true,
            });
          }
        });
    </script>
  </body>
</html>
