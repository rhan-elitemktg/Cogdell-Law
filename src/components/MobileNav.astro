---
import { Image } from "astro:assets";
import logoLight from "../assets/cogdell-logo-light.png";
import { isOnTrail, normalizePath, type NavItem } from "../data/navigation";

interface Props {
  items: NavItem[];
  pathname: string;
  phone: string;
  phoneHref: string;
}

const { items, pathname, phone, phoneHref } = Astro.props;
const current = normalizePath(pathname);

// Flatten the nav tree into sibling "panels" (one per menu level). Each parent
// with children gets its own panel; drill buttons reference the target panel id.
// IDs encode the index path (root-2-0…) so a drill target is always
// `${panel.id}-${itemIndex}`.
type Panel = { id: string; title: string; parentId: string | null; items: NavItem[] };
const panels: Panel[] = [];
const buildPanels = (
  items: NavItem[],
  id: string,
  title: string,
  parentId: string | null,
) => {
  panels.push({ id, title, parentId, items });
  items.forEach((item, i) => {
    if (item.children?.length) {
      buildPanels(item.children, `${id}-${i}`, item.label, id);
    }
  });
};
buildPanels(items, "root", "Menu", null);
---

<div class="mobile-nav">
  <div class="drawer-overlay" data-drawer-overlay></div>

  <aside
    id="mobile-drawer"
    class="drawer"
    aria-label="Site menu"
    aria-hidden="true"
    inert
  >
    <div class="drawer__bar">
      <button class="drawer__back" type="button" data-drawer-back hidden aria-label="Back">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 5l-7 7 7 7" /></svg>
      </button>
      <span class="drawer__title" data-drawer-title>Menu</span>
      <button class="drawer__close" type="button" data-drawer-close aria-label="Close menu">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
      </button>
    </div>

    <div class="drawer__body">
      {
        panels.map((panel) => (
          <ul
            class:list={["panel", { "is-open": panel.id === "root" }]}
            data-panel-id={panel.id}
            data-parent-id={panel.parentId ?? ""}
            data-title={panel.title}
          >
            {panel.items.map((item, i) => {
              const hasChildren = !!item.children?.length;
              const target = `${panel.id}-${i}`;
              const active = isOnTrail(item, current);
              return (
                <li class="panel__item">
                  {item.href ? (
                    <a
                      href={item.href}
                      class:list={["panel__link", { active }]}
                      aria-current={
                        normalizePath(item.href) === current ? "page" : undefined
                      }
                    >
                      <span>{item.label}</span>
                    </a>
                  ) : (
                    <button
                      class="panel__link panel__drill"
                      type="button"
                      data-drawer-target={target}
                    >
                      <span>{item.label}</span>
                      <svg class="panel__chevron" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7" /></svg>
                    </button>
                  )}
                  {item.href && hasChildren && (
                    <button
                      class="panel__expand"
                      type="button"
                      data-drawer-target={target}
                      aria-label={`Open ${item.label} submenu`}
                    >
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7" /></svg>
                    </button>
                  )}
                </li>
              );
            })}
          </ul>
        ))
      }
    </div>

    <div class="drawer__footer">
      <span class="drawer__logo">
        <Image src={logoLight} alt="Cogdell Law Firm" densities={[1, 2]} />
      </span>
      <a href={phoneHref} class="drawer__cta">
        <span class="drawer__cta-label">Call to Discuss Your Case</span>
        <span class="drawer__cta-phone">{phone}</span>
      </a>
    </div>
  </aside>
</div>

<style>
  /* The whole mobile nav is desktop-hidden; the header toggle only exists at
     the nav-collapse breakpoint (1200px) and below. */
  @media (min-width: 1201px) {
    .mobile-nav {
      display: none;
    }
  }

  /* ---- Overlay ---- */
  .drawer-overlay {
    position: fixed;
    inset: 0;
    background-color: rgba(7, 16, 29, 0.55);
    opacity: 0;
    visibility: hidden;
    transition:
      opacity var(--transition),
      visibility var(--transition);
    z-index: 90;
  }
  .mobile-nav.is-open .drawer-overlay {
    opacity: 1;
    visibility: visible;
  }

  /* ---- Drawer ---- */
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(380px, 88vw);
    display: flex;
    flex-direction: column;
    background-color: var(--cog-navy);
    border-left: 3px solid var(--cog-accent);
    box-shadow: -18px 0 50px rgba(0, 0, 0, 0.45);
    transform: translateX(100%);
    /* Hidden when closed so the box-shadow doesn't bleed back into the page.
       Visibility is transitioned so the slide-out animation still shows. */
    visibility: hidden;
    transition:
      transform var(--transition),
      visibility var(--transition);
    z-index: 100;
  }
  .mobile-nav.is-open .drawer {
    transform: translateX(0);
    visibility: visible;
  }
  @media (max-width: 650px) {
    .drawer {
      width: 100vw;
      border-left: none;
      border-top: 3px solid var(--cog-accent);
    }
  }

  /* ---- Drawer bar (back / title / close) ---- */
  .drawer__bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--cog-line);
    min-height: 4.5rem;
  }
  .drawer__title {
    flex: 1;
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--cog-white);
    line-height: 1;
  }
  .drawer__back,
  .drawer__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    background: none;
    border: 1px solid var(--cog-line-strong);
    border-radius: var(--radius);
    color: var(--cog-white);
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition);
  }
  .drawer__back:hover,
  .drawer__close:hover {
    color: var(--cog-accent);
    border-color: var(--cog-accent);
  }
  .drawer__back[hidden] {
    display: none;
  }

  /* ---- Panels (drill-down) ---- */
  .drawer__body {
    position: relative;
    flex: 1;
    overflow: hidden;
  }
  .panel {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: var(--space-2) 0;
    overflow-y: auto;
    background-color: var(--cog-navy);
    transform: translateX(100%);
    transition: transform var(--transition);
  }
  .panel.is-open {
    transform: translateX(0);
  }

  .panel__item {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--cog-line);
  }
  .panel__link {
    flex: 1;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    width: 100%;
    padding: var(--space-4) var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: left;
    text-decoration: none;
    color: var(--cog-white);
    background: none;
    border: 0;
    cursor: pointer;
    transition: color var(--transition), background-color var(--transition);
  }
  .panel__link:hover,
  .panel__link.active {
    color: var(--cog-accent);
  }
  .panel__drill {
    justify-content: space-between;
  }

  /* Chevron inside a drill-only row + expand button for parents-with-a-page */
  .panel__chevron {
    flex-shrink: 0;
  }
  .panel__expand {
    display: inline-flex;
    align-items: center;
    padding-inline: var(--space-6);
    background: none;
    border: 0;
    border-left: 1px solid var(--cog-line);
    color: var(--cog-navlink);
    cursor: pointer;
    transition: color var(--transition), background-color var(--transition);
  }
  .panel__expand:hover {
    color: var(--cog-accent);
    background-color: var(--cog-navy-glow);
  }

  /* ---- Footer (logo + CTA) ---- */
  .drawer__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-8) var(--space-6);
    text-align: center;
    background-color: var(--cog-navy-deep);
  }
  .drawer__logo {
    line-height: 0;
  }
  .drawer__logo :global(img) {
    height: 2.75rem; /* 44px */
    width: auto;
  }
  .drawer__cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    text-decoration: none;
  }
  .drawer__cta-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .drawer__cta-phone {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--cog-white);
    transition: color var(--transition);
    line-height: 1;
  }
  .drawer__cta:hover .drawer__cta-phone {
    color: var(--cog-cream);
  }

  @media (prefers-reduced-motion: reduce) {
    .drawer,
    .drawer-overlay,
    .panel {
      transition: none;
    }
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>(".mobile-nav");
  if (root) {
    const drawer = root.querySelector<HTMLElement>(".drawer")!;
    const overlay = root.querySelector<HTMLElement>("[data-drawer-overlay]")!;
    const backBtn = root.querySelector<HTMLButtonElement>("[data-drawer-back]")!;
    const closeBtn = root.querySelector<HTMLButtonElement>("[data-drawer-close]")!;
    const titleEl = root.querySelector<HTMLElement>("[data-drawer-title]")!;
    const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");

    // Drill-down state: a stack of open panel ids (root is always the base).
    const stack: string[] = ["root"];
    const panelById = (id: string) =>
      root.querySelector<HTMLElement>(`[data-panel-id="${id}"]`);

    const updateBar = () => {
      const currentId = stack[stack.length - 1];
      const panel = panelById(currentId);
      titleEl.textContent = panel?.dataset.title ?? "Menu";
      backBtn.hidden = stack.length <= 1;
    };

    const drill = (id: string) => {
      const panel = panelById(id);
      if (!panel) return;
      panel.classList.add("is-open");
      stack.push(id);
      updateBar();
    };

    const back = () => {
      if (stack.length <= 1) return;
      const id = stack.pop()!;
      panelById(id)?.classList.remove("is-open");
      updateBar();
    };

    const resetPanels = () => {
      while (stack.length > 1) {
        const id = stack.pop()!;
        panelById(id)?.classList.remove("is-open");
      }
      updateBar();
    };

    const open = () => {
      root.classList.add("is-open");
      document.body.classList.add("drawer-open");
      drawer.setAttribute("aria-hidden", "false");
      drawer.removeAttribute("inert");
      toggle?.setAttribute("aria-expanded", "true");
      closeBtn.focus();
    };

    const close = () => {
      root.classList.remove("is-open");
      document.body.classList.remove("drawer-open");
      drawer.setAttribute("aria-hidden", "true");
      drawer.setAttribute("inert", "");
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.focus();
      // Reset drill state after the drawer has slid away.
      window.setTimeout(resetPanels, 300);
    };

    toggle?.addEventListener("click", () =>
      root.classList.contains("is-open") ? close() : open(),
    );
    overlay.addEventListener("click", close);
    closeBtn.addEventListener("click", close);
    backBtn.addEventListener("click", back);

    root.querySelectorAll<HTMLElement>("[data-drawer-target]").forEach((btn) => {
      btn.addEventListener("click", () => drill(btn.dataset.drawerTarget!));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && root.classList.contains("is-open")) close();
    });
  }
</script>
