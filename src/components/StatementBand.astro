---
// Homepage full-bleed statement band — team photo with a bottom scrim; eyebrow
// + lockup on the left, positioning statement + link on the right.
//
// Named for what it is, not what it says: the copy is editable, so a name like
// "VideoBand" (there is no video) or "BoutiqueBand" dates immediately.
import { Image } from "astro:assets";
import { PortableText } from "astro-portabletext";
import { proseComponents } from "./prose/components";
import Eyebrow from "./Eyebrow.astro";
import StatementBody from "./statement/StatementBody.astro";
import teamPhoto from "../assets/team-group.png";
import { getHomeStatement } from "../sanity/lib/homePage";

// Homepage-only, so it fetches its own content (D9). The team photo is
// art-directed and full-bleed, so it stays in the repo (D6).
const statement = await getHomeStatement();

if (!statement) {
  throw new Error(
    "No Statement Band found on the Home Page in Sanity.\n" +
      "Add it in the Studio at /admin → Home Page, or seed it with:\n" +
      "  npx sanity exec scripts/seed-statement-band.ts --with-user-token",
  );
}
---

<section class="statement-band">
  <div class="statement-band__media">
    <Image
      src={teamPhoto}
      alt="The attorneys of Cogdell Law Firm"
      widths={[900, 1300]}
      sizes="100vw"
      class="statement-band__bg lazy-fade"
    />
    <div class="statement-band__overlay" aria-hidden="true"></div>
  </div>

  <div class="container statement-band__inner">
    <div class="statement-band__lead">
      <Eyebrow>{statement.eyebrow}</Eyebrow>
      <h2 class="statement-band__heading">
        <span class="statement-band__heading-italic">{statement.headingItalic}</span>
        <span class="statement-band__heading-bold">{statement.headingBold}</span>
      </h2>
    </div>

    <div class="statement-band__aside">
      <PortableText
        value={statement.body}
        components={{
          ...proseComponents,
          block: { ...proseComponents.block, normal: StatementBody },
        }}
      />
      <a href={statement.cta?.href} class="btn btn--outline statement-band__cta">
        {statement.cta?.label}
        <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .statement-band {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: clamp(560px, 72vh, 760px);
    overflow: hidden;
    background-color: var(--cog-navy-deep);
    color: var(--cog-white);
  }

  /* Full-bleed media layer (behind the copy) on desktop. */
  .statement-band__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .statement-band__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  /* Darken from the bottom up so the photo reads clear while the copy stays legible.
     The bottom 20px is fully solid navy before it feathers, so the band blends
     seamlessly into the solid CTA bar below. */
  .statement-band__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(7, 16, 29, 1) 0,
      rgba(7, 16, 29, 1) 20px,
      rgba(7, 16, 29, 0.6) 36%,
      rgba(7, 16, 29, 0) 68%,
      rgba(7, 16, 29, 0.15) 100%
    );
  }

  .statement-band__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: var(--space-16);
    align-items: end;
    padding-block-end: var(--space-16);
  }

  /* ---- Heading lockup ---- */
  .statement-band__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .statement-band__heading-italic,
  .statement-band__heading-bold {
    display: block;
    font-size: clamp(2.375rem, 4.4vw, 3.75rem); /* 38 → 60px */
  }
  .statement-band__heading-italic {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-cream);
  }
  .statement-band__heading-bold {
    margin-top: 4px;
    font-weight: 700;
    color: var(--cog-white);
  }

  /* ---- Aside (body + link) ---- */
  .statement-band__aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 560px;
    justify-self: end;
  }
  /* Emitted by StatementBody.astro (a Portable Text renderer), so it carries no
     scoping attribute of its own — see F14. The scoped .statement-band__aside
     parent bounds the :global. */
  .statement-band__aside :global(.statement-band__body) {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-white);
  }
  /* Keep the button content-width on desktop (the global rule makes it full-width on mobile). */
  .statement-band__cta {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  /* ---- Responsive ---- */
  /* On tablet/mobile, stack the full (uncropped) photo above the copy so every
     attorney stays visible, with the image bottom fading into the navy block. */
  @media (max-width: 900px) {
    .statement-band {
      display: block;
      min-height: 0;
    }
    .statement-band__media {
      position: relative;
      inset: auto;
    }
    .statement-band__bg {
      position: relative;
      inset: auto;
      height: auto; /* natural aspect — shows the whole team */
    }
    .statement-band__overlay {
      inset: auto 0 0 0;
      height: 60%;
      background: linear-gradient(
        180deg,
        rgba(7, 16, 29, 0) 0%,
        rgba(7, 16, 29, 0.55) 45%,
        rgba(7, 16, 29, 0.9) 78%,
        rgba(7, 16, 29, 1) 100%
      );
    }
    .statement-band__inner {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--space-8);
      padding-block: var(--space-8) var(--space-16);
    }
    .statement-band__aside {
      justify-self: start;
      max-width: none;
    }
  }
</style>
