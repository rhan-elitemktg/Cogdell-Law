---
// Homepage "Common Questions" section — intro on the left, accordion on the right.
// Native <details> with a shared name = exclusive accordion, no JS.
//
// Homepage-only, so it fetches its own content (D9). Questions are `faq`
// documents (F1); the header is page copy (F16).
import { PortableText } from "astro-portabletext";
import Eyebrow from "./Eyebrow.astro";
import FaqLede from "./faq/FaqLede.astro";
import FaqAnswer from "./faq/FaqAnswer.astro";
import { proseComponents } from "./prose/components";
import { getFaqBand } from "../sanity/lib/faqs";

const band = await getFaqBand();

// The homepage curates which FAQs it shows via a reference array on the band, so
// editors add/remove them right in the Home Page document (F1 / the about.featured
// pattern). The master FAQ list lives as `faq` documents.
const faqs = band?.questions ?? [];

if (!band || !faqs.length) {
  throw new Error(
    "No FAQ band or questions found in Sanity.\n" +
      "Add questions to the Home Page → FAQ section, or seed them with:\n" +
      "  npx sanity exec scripts/seed-faqs.ts --with-user-token",
  );
}
---

<section class="faq">
  <div class="container faq__inner">
    <div class="faq__intro">
      <Eyebrow>{band.eyebrow}</Eyebrow>
      <h2 class="faq__heading">
        <span class="faq__heading-lead">{band.headingLead}</span>
        <span class="faq__heading-strong">{band.headingStrong}</span>
      </h2>
      <PortableText
        value={band.lede}
        components={{
          ...proseComponents,
          block: { ...proseComponents.block, normal: FaqLede },
        }}
      />
    </div>

    <div class="faq__accordion">
      {
        faqs.map((item, i) => (
          <details class="faq__item" name="faq" open={i === 0}>
            <summary class="faq__summary">
              <span class="faq__q">{item.question}</span>
              <svg class="faq__icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
            </summary>
            <div class="faq__answer">
              <PortableText
                value={item.answer}
                components={{
                  ...proseComponents,
                  block: { ...proseComponents.block, normal: FaqAnswer },
                }}
              />
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    background-color: var(--cog-paper);
    /* One speed drives both the top-bar wipe and the content expand → in sync. */
    --faq-speed: 0.5s;
    /* Lets the <details> content animate between height 0 and auto. */
    interpolate-size: allow-keywords;
  }
  .faq__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    column-gap: var(--space-16);
    align-items: start;
    padding-block: var(--space-section);
  }

  /* ---- Intro ---- */
  .faq__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3vw, 3.25rem); /* 32 → 52px, eased so the long line fits */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .faq__heading-lead,
  .faq__heading-strong {
    display: block;
  }
  .faq__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .faq__heading-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }
  .faq__intro :global(.faq__lede) {
    max-width: 380px;
    margin-top: var(--space-6);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }

  /* ---- Accordion ---- */
  .faq__accordion {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .faq__item {
    position: relative;
    background-color: var(--cog-paper-card);
  }
  /* Accent bar wipes across the top when the item opens (like the attorney cards). */
  .faq__item::before {
    content: "";
    position: absolute;
    z-index: 1;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--cog-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--faq-speed) var(--ease);
  }
  .faq__item[open]::before {
    transform: scaleX(1);
  }
  /* Expand/collapse the answer at the same speed as the bar. */
  .faq__item::details-content {
    height: 0;
    overflow: clip;
    transition-property: height, content-visibility;
    transition-duration: var(--faq-speed);
    transition-timing-function: var(--ease);
    transition-behavior: allow-discrete;
  }
  .faq__item[open]::details-content {
    height: auto;
  }
  @media (prefers-reduced-motion: reduce) {
    .faq__item::before,
    .faq__item::details-content {
      transition: none;
    }
  }
  .faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding: var(--space-6);
    cursor: pointer;
    list-style: none;
  }
  .faq__summary::-webkit-details-marker {
    display: none;
  }
  .faq__q {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-xl);
    line-height: 1.25;
    color: var(--cog-ink);
  }
  .faq__icon {
    flex-shrink: 0;
    color: var(--cog-ink-muted);
    transition: transform var(--faq-speed) var(--ease);
  }
  .faq__item[open] .faq__icon {
    transform: rotate(45deg); /* + becomes × */
  }
  .faq__answer {
    padding: 0 var(--space-6) var(--space-6);
  }
  .faq__answer :global(p) {
    max-width: 72ch;
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .faq__inner {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--space-12);
    }
  }
</style>
