---
// Attorney bio hero: a full-bleed image-only band (the same courthouse-steps
// photo across every attorney, per brand) with the profile card overlapping up
// into it — portrait, name, contact, and practice-area tags.
import { Image } from "astro:assets";
import type { Attorney } from "../../data/attorneys";
// Shared hero image for ALL attorney bios (matches the Trial Experience hero).
import heroImage from "../../assets/firm-steps.jpg";

interface Props {
  attorney: Attorney;
}

const { attorney }: Props = Astro.props;
const telHref = `tel:${attorney.phone.replace(/\D/g, "")}`;
const emailHref = attorney.email ? `mailto:${attorney.email}` : "#contact";
---

<section class="a-hero">
  <Image
    src={heroImage}
    alt=""
    widths={[900, 1200, 1584]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    class="a-hero__bg"
  />
  <div class="a-hero__overlay" aria-hidden="true"></div>
  <div class="container a-hero__inner">
    <p class="a-hero__title">
      A Legacy of Legal Victories in Fraud &amp; White Collar Crime Defense
    </p>
  </div>
</section>

<section class="a-profile">
  <div class="container">
    <div class="a-profile__card">
      <Image
        src={attorney.photo}
        alt={attorney.photoAlt}
        widths={[260, 400, 520]}
        sizes="(max-width: 860px) 220px, 260px"
        loading="eager"
        class="a-profile__photo"
      />
      <div class="a-profile__meta">
        <div class="a-profile__headrow">
          <div class="a-profile__id">
            <span class="a-profile__role">{attorney.role}</span>
            <h1 class="a-profile__name">{attorney.name}</h1>
          </div>
          <div class="a-profile__contact">
            <a class="a-profile__cta" href={telHref}>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"></path></svg>
              {attorney.phone}
            </a>
            <a class="a-profile__cta" href={emailHref}>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg>
              Email {attorney.name.split(" ")[0]}
            </a>
          </div>
        </div>
        <div class="a-profile__rule" aria-hidden="true"></div>
        {
          attorney.practiceTags.length > 0 && (
            <ul class="a-profile__tags">
              {attorney.practiceTags.map((tag) => (
                <li class="a-profile__tag">{tag}</li>
              ))}
            </ul>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Image-only hero band ---- */
  .a-hero {
    position: relative;
    overflow: hidden;
    min-height: clamp(320px, 32vw, 460px);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--cog-navy-deep);
  }
  .a-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 28%;
  }
  /* Same left-to-right navy scrim as the Trial Experience (PageHero) overlay. */
  .a-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(7, 16, 29, 0.96) 0%,
      rgba(7, 16, 29, 0.88) 42%,
      rgba(7, 16, 29, 0.6) 78%,
      rgba(7, 16, 29, 0.4) 100%
    );
  }

  /* Centered display tagline; padding-bottom lifts it clear of the card below. */
  .a-hero__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-bottom: var(--space-16);
  }
  .a-hero__title {
    max-width: 40rem;
    margin: 0 auto;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 600;
    font-size: clamp(1.875rem, 3.4vw, 3rem);
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--cog-cream);
    text-wrap: balance;
  }

  /* ---- Profile card (overlaps hero) ---- */
  .a-profile {
    position: relative;
    z-index: 2;
    margin-top: -96px;
    padding-bottom: var(--space-section);
  }
  .a-profile__card {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-12);
    align-items: center;
    padding: var(--space-12);
    background-color: var(--cog-navy);
    border: 1px solid var(--cog-navy-glow);
    border-top: 3px solid var(--cog-accent);
    box-shadow: 0 30px 70px rgba(7, 16, 29, 0.35);
  }
  .a-profile__photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    object-position: center 20%;
    border: 1px solid var(--cog-line-strong);
  }
  /* Name + contact CTAs share a row, pushed to opposite ends. */
  .a-profile__headrow {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4) var(--space-8);
  }
  .a-profile__id {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .a-profile__role {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cog-gold);
  }
  .a-profile__name {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2.25rem, 3.4vw, 3rem);
    line-height: 1.05;
    color: var(--cog-white);
  }
  .a-profile__rule {
    height: 1px;
    background-color: var(--cog-line-strong);
    margin: var(--space-6) 0;
  }
  .a-profile__contact {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4) var(--space-6);
  }
  .a-profile__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--cog-white);
    text-decoration: none;
    transition: color var(--transition);
  }
  .a-profile__cta svg {
    flex-shrink: 0;
    color: var(--cog-accent);
  }
  .a-profile__cta:hover {
    color: var(--cog-cream);
  }
  .a-profile__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
  }
  .a-profile__tag {
    padding: 6px 14px;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cog-cream);
    border: 1px solid var(--cog-line-strong);
    border-radius: 100px;
  }

  @media (max-width: 860px) {
    .a-profile__card {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      padding: var(--space-6);
    }
    .a-profile__photo {
      max-width: 100%;
    }
    .a-profile__headrow {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-6);
    }
  }
</style>
