---
// Homepage "In the News" band — featured press mention + numbered 02/03/04 list,
// on dark. Reads the latest items from the news data; external items link out.
import Eyebrow from "./Eyebrow.astro";
import { latestNews, type NewsMedia } from "../data/news";

const featured = latestNews[0];
const rest = latestNews.slice(1, 4);

const MEDIA_LABEL: Record<NewsMedia, string> = {
  article: "Article",
  video: "Video",
  podcast: "Podcast",
};
const MEDIA_VERB: Record<NewsMedia, string> = {
  article: "Read more",
  video: "Watch",
  podcast: "Listen",
};

// Card link target: external press mention (new tab) or an owned /news/[slug].
const linkAttrs = (n: { externalUrl?: string; slug: string }) =>
  n.externalUrl
    ? { href: n.externalUrl, target: "_blank", rel: "noopener noreferrer" }
    : { href: `/news/${n.slug}` };
---

<section class="blog">
  <div class="container blog__inner">
    <div class="blog__head">
      <div class="blog__head-left">
        <Eyebrow>Press &amp; Media</Eyebrow>
        <h2 class="blog__heading">
          <span class="blog__heading-lead">In the</span>
          <span class="blog__heading-strong"> News.</span>
        </h2>
      </div>
      <p class="blog__lede">
        Our attorneys are known throughout Texas and nationally for handling
        high-profile, high-stakes cases — work that has drawn coverage from
        local, national, and global media. A selection of recent articles,
        interviews, and appearances.
      </p>
    </div>

    <div class="blog__grid">
      <!-- Featured (01) -->
      <a class="blog__feature" {...linkAttrs(featured)}>
        <span class="blog__feature-num" aria-hidden="true">01</span>
        <span class="blog__tag">Featured</span>
        <div class="blog__meta">
          <span class="blog__cat">{featured.outlet}</span>
          <span class="blog__dot" aria-hidden="true"></span>
          <span class="blog__date">{MEDIA_LABEL[featured.media]}</span>
        </div>
        <h3 class="blog__feature-title">{featured.title}</h3>
        <p class="blog__feature-excerpt">{featured.summary}</p>
        <span class="blog__more">
          {featured.ctaLabel ?? MEDIA_VERB[featured.media]}
          <svg class="blog__more-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </span>
      </a>

      <!-- 02 / 03 / 04 list -->
      <div class="blog__list">
        {
          rest.map((post, i) => (
            <a class="blog__post" {...linkAttrs(post)}>
              <span class="blog__post-num" aria-hidden="true">
                {String(i + 2).padStart(2, "0")}
              </span>
              <div class="blog__meta">
                <span class="blog__cat">{post.outlet}</span>
                <span class="blog__dot" aria-hidden="true" />
                <span class="blog__date">{MEDIA_LABEL[post.media]}</span>
              </div>
              <h3 class="blog__post-title">{post.title}</h3>
            </a>
          ))
        }
      </div>
    </div>

    <div class="blog__footer">
      <a class="btn btn--primary" href="/news">
        View All News
        <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .blog {
    background: radial-gradient(
      120% 80% at 50% 0%,
      var(--cog-navy-glow) 0%,
      var(--cog-navy) 38%,
      var(--cog-navy-deep) 100%
    );
    border-top: 1px solid var(--cog-line);
    color: var(--cog-white);
  }
  .blog__inner {
    padding-block: var(--space-section);
  }

  /* ---- Header ---- */
  .blog__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-16);
    align-items: start;
    margin-bottom: var(--space-16);
  }
  .blog__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4.4vw, 3.75rem); /* 40 → 60px */
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .blog__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .blog__heading-strong {
    font-weight: 700;
    color: var(--cog-white);
  }
  .blog__lede {
    max-width: 790px;
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-body);
  }

  /* ---- Shared meta row ---- */
  .blog__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .blog__cat {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-navlink);
  }
  .blog__dot {
    width: 4px;
    height: 4px;
    flex-shrink: 0;
    border-radius: 50%;
    background-color: var(--cog-muted);
  }
  .blog__date {
    font-size: var(--text-sm);
    color: var(--cog-muted);
  }

  /* ---- Grid ---- */
  .blog__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: var(--space-16);
    align-items: flex-start;
  }

  /* ---- Featured card ---- */
  .blog__feature {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: var(--space-12);
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--cog-line);
    border-top: 3px solid var(--cog-accent);
    color: inherit;
    text-decoration: none;
  }
  .blog__feature-num {
    position: absolute;
    top: -25px;
    right: var(--space-8);
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    font-size: 150px;
    line-height: 1;
    color: rgba(255, 255, 255, 0.06);
    pointer-events: none;
  }
  .blog__tag {
    align-self: flex-start;
    padding: 4px 10px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--cog-accent);
    border: 1px solid var(--cog-accent);
  }
  .blog__feature .blog__meta {
    margin-top: var(--space-8);
  }
  .blog__feature-title {
    margin-top: var(--space-4);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.875rem, 3vw, 2.625rem); /* 30 → 42px */
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--cog-white);
    text-wrap: balance;
    transition: color var(--transition);
  }
  .blog__feature-excerpt {
    max-width: 560px;
    margin: var(--space-4) 0 var(--space-8);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-body);
  }
  .blog__more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .blog__more-icon {
    flex-shrink: 0;
    transition: transform var(--transition);
  }
  .blog__feature:hover .blog__more-icon {
    transform: translateX(4px);
  }
  .blog__feature:hover .blog__feature-title {
    color: var(--cog-cream);
  }

  /* ---- List (02/03/04) ---- */
  .blog__list {
    display: flex;
    flex-direction: column;
  }
  .blog__post {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block: var(--space-8);
    border-top: 1px solid var(--cog-line);
    color: inherit;
    text-decoration: none;
  }
  .blog__post-num {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    font-size: var(--text-xl);
    line-height: 1;
    color: var(--cog-accent);
  }
  .blog__post-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 2vw, 1.875rem); /* 24 → 30px */
    line-height: 1.18;
    letter-spacing: -0.005em;
    color: var(--cog-white);
    text-wrap: pretty;
    transition: color var(--transition);
  }
  .blog__post:hover .blog__post-title {
    color: var(--cog-cream);
  }

  /* ---- Footer ---- */
  .blog__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-14);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .blog__head,
    .blog__grid {
      grid-template-columns: 1fr;
    }
    .blog__head {
      row-gap: var(--space-8);
    }
    .blog__grid {
      row-gap: var(--space-8);
    }
  }
</style>
