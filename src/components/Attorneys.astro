---
// Homepage "The Firm" attorneys section — header + four attorney cards.
// Desktop: 4-up grid. Tablet/mobile: horizontal peek carousel (no scrollbar).
import { Image } from "astro:assets";
import Eyebrow from "./Eyebrow.astro";
import danPhoto from "../assets/attorneys/dan-cogdell.jpg";
import aishaPhoto from "../assets/attorneys/aisha-dennis.jpg";
import anthonyPhoto from "../assets/attorneys/anthony-osso.jpg";
import brentPhoto from "../assets/attorneys/brent-newton.jpg";

const attorneys = [
  {
    photo: danPhoto,
    name: "Dan L. Cogdell",
    role: "Founding Attorney",
    credential: "40+ years — white collar, civil & federal criminal defense",
    href: "/attorney/cogdell-dan-l",
  },
  {
    photo: aishaPhoto,
    name: "Aisha Dennis",
    role: "Attorney",
    credential: "Federal litigation, white collar defense & complex trials",
    href: "/#",
  },
  {
    photo: anthonyPhoto,
    name: "Anthony Osso",
    role: "Attorney",
    credential: "Federal criminal cases & complex trials",
    href: "/attorney/osso-anthony",
  },
  {
    photo: brentPhoto,
    name: "Brent E. Newton",
    role: "Attorney",
    credential: "Federal appeals & post-conviction",
    href: "/attorney/newton-brent-e",
  },
];
---

<section class="attorneys">
  <div class="container">
    <div class="attorneys__head">
      <div class="attorneys__head-left">
        <Eyebrow>The Firm</Eyebrow>
        <h2 class="attorneys__heading">
          <span class="attorneys__heading-lead">Trial Lawyers</span>
          <span class="attorneys__heading-strong">Who Fight to Win.</span>
        </h2>
      </div>
      <div class="attorneys__head-right">
        <p class="attorneys__lede">
          The Cogdell Law Firm team defends individuals, executives, and
          companies throughout Texas and across the country — federal
          investigations, white collar matters, complex civil disputes, and the
          cases other firms turn away.
        </p>
      </div>
    </div>

    <div class="attorneys__grid">
      {
        attorneys.map((a) => (
          <a class="attorneys__card" href={a.href}>
            <div class="attorneys__photo">
              <Image
                src={a.photo}
                alt={a.name}
                widths={[300, 460, 600, 790]}
                sizes="(max-width: 650px) 80vw, (max-width: 900px) 44vw, 22vw"
                class="attorneys__photo-img lazy-fade"
              />
              <span class="attorneys__bar" aria-hidden="true" />
            </div>
            <div class="attorneys__body">
              <h3 class="attorneys__name">{a.name}</h3>
              <span class="attorneys__role">{a.role}</span>
              <p class="attorneys__cred">{a.credential}</p>
              <span class="attorneys__profile">
                <span class="attorneys__profile-label">View Profile</span>
                <svg class="attorneys__profile-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .attorneys {
    background-color: var(--cog-paper);
  }
  .attorneys .container {
    padding-block: var(--space-section);
  }

  /* ---- Header ---- */
  .attorneys__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-16);
    align-items: start;
    margin-bottom: var(--space-12);
  }
  .attorneys__head-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4); /* standard eyebrow → heading gap */
  }
  .attorneys__heading {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2.375rem, 4.2vw, 3.625rem); /* 38 → 58px */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .attorneys__heading-lead,
  .attorneys__heading-strong {
    display: block;
  }
  .attorneys__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .attorneys__heading-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }
  .attorneys__lede {
    max-width: 660px;
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }

  /* ---- Card grid ---- */
  .attorneys__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
  }

  .attorneys__card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background-color: var(--cog-paper-card);
    box-shadow: 0 12px 30px rgba(14, 27, 45, 0.08);
    color: inherit;
    text-decoration: none;
  }
  .attorneys__photo {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }
  .attorneys__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    /* Keep the fade-in opacity transition alongside the hover-zoom. */
    transition:
      transform 0.6s var(--ease),
      opacity 0.7s var(--ease);
  }
  .attorneys__card:hover .attorneys__photo-img {
    transform: scale(1.045);
  }
  /* Accent bar wipes across the top of the card on hover. */
  .attorneys__bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--cog-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }
  .attorneys__card:hover .attorneys__bar {
    transform: scaleX(1);
  }

  .attorneys__body {
    display: flex;
    flex: 1; /* fill the card so View Profile can pin to the bottom */
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
  }
  .attorneys__name {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.375rem, 1.2rem + 0.6vw, 1.5625rem); /* 22 → 25px */
    line-height: 1.05;
    color: var(--cog-ink);
  }
  .attorneys__role {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .attorneys__cred {
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--cog-ink-body);
  }
  .attorneys__profile {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: var(--space-2);
    margin-top: auto; /* pin to the bottom so all cards align */
    padding-top: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-ink);
  }
  .attorneys__profile-label {
    border-bottom: 1px solid var(--cog-ink);
    padding-bottom: 3px;
  }
  .attorneys__profile-icon {
    color: var(--cog-accent);
    transition: transform var(--transition);
  }
  .attorneys__card:hover .attorneys__profile-icon {
    transform: translateX(4px);
  }

  /* ---- Responsive: horizontal peek carousel (no scrollbar) ---- */
  @media (max-width: 900px) {
    .attorneys__head {
      grid-template-columns: 1fr;
      row-gap: var(--space-8);
      margin-bottom: var(--space-8);
    }
    /* First card honors the container padding (left); the row bleeds to the right
       screen edge so the peek runs off-screen with no right gap mid-scroll, while
       the matching trailing padding lets the last card rest one padding in from the
       edge. Both must match .container's actual padding at this width (32px ≤1360). */
    .attorneys__grid {
      display: flex;
      gap: var(--space-6);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      margin-inline-end: calc(-1 * var(--space-8));
      padding-inline-end: var(--space-8);
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* legacy Edge */
    }
    .attorneys__grid::-webkit-scrollbar {
      display: none; /* Chrome, Safari */
    }
    .attorneys__card {
      flex: 0 0 44%; /* tablet: next card peeks */
      scroll-snap-align: start;
    }
  }
  @media (max-width: 650px) {
    .attorneys__grid {
      margin-inline-end: calc(-1 * var(--space-6)); /* match container padding (24px) */
      padding-inline-end: var(--space-6);
    }
    .attorneys__card {
      flex-basis: 64%; /* mobile: smaller cards, next card peeks */
    }
    .attorneys__photo {
      aspect-ratio: 3 / 3;
    }
  }
</style>
