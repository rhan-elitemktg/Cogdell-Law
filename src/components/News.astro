---
// Homepage "In the News" band — one featured article on the left, the 3 newest
// (excluding the featured) numbered on the right, on dark. F20.
//
// Homepage-only, so it fetches its own content (D9). Items are `newsItem`
// documents; the featured pick + header are on the Home Page News section.
import { PortableText } from "astro-portabletext";
import Eyebrow from "./Eyebrow.astro";
import NewsLede from "./news/NewsLede.astro";
import { proseComponents } from "./prose/components";
import { getHomeNews } from "../sanity/lib/news";

type NewsMedia = "article" | "video" | "podcast";

const band = await getHomeNews();

if (!band?.featured) {
  throw new Error(
    "No News band or featured article found in Sanity.\n" +
      "Set Home Page → News → Featured, or seed it with:\n" +
      "  npx sanity exec scripts/seed-news.ts --with-user-token",
  );
}

const featured = band.featured;
const rest = band.rest ?? [];

const MEDIA_LABEL: Record<NewsMedia, string> = {
  article: "Article",
  video: "Video",
  podcast: "Podcast",
};
const MEDIA_VERB: Record<NewsMedia, string> = {
  article: "Read more",
  video: "Watch",
  podcast: "Listen",
};

// External mention → new tab; owned article → /news/[slug].
const linkAttrs = (n: { linkType?: string | null; externalUrl?: string | null; slug?: string | null }) =>
  n.linkType === "external" && n.externalUrl
    ? { href: n.externalUrl, target: "_blank", rel: "noopener noreferrer" }
    : { href: `/news/${n.slug}` };
---

<section class="news">
  <div class="container news__inner">
    <div class="news__head">
      <div class="news__head-left">
        <Eyebrow>{band.eyebrow}</Eyebrow>
        <h2 class="news__heading">
          <span class="news__heading-lead">{band.headingLead}</span>
          <span class="news__heading-strong"> {band.headingStrong}</span>
        </h2>
      </div>
      <PortableText
        value={band.lede}
        components={{
          ...proseComponents,
          block: { ...proseComponents.block, normal: NewsLede },
        }}
      />
    </div>

    <div class="news__grid">
      <!-- Featured (01) -->
      <a class="news__feature" {...linkAttrs(featured)}>
        <span class="news__feature-num" aria-hidden="true">01</span>
        <span class="news__tag">Featured</span>
        <div class="news__meta">
          <span class="news__cat">{featured.outlet}</span>
          <span class="news__dot" aria-hidden="true"></span>
          <span class="news__date">{MEDIA_LABEL[featured.media]}</span>
        </div>
        <h3 class="news__feature-title">{featured.title}</h3>
        <p class="news__feature-excerpt">{featured.summary}</p>
        <span class="news__more">
          {featured.ctaLabel ?? MEDIA_VERB[featured.media]}
          <svg class="news__more-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </span>
      </a>

      <!-- 02 / 03 / 04 list -->
      <div class="news__list">
        {
          rest.map((post, i) => (
            <a class="news__post" {...linkAttrs(post)}>
              <span class="news__post-num" aria-hidden="true">
                {String(i + 2).padStart(2, "0")}
              </span>
              <div class="news__meta">
                <span class="news__cat">{post.outlet}</span>
                <span class="news__dot" aria-hidden="true" />
                <span class="news__date">{MEDIA_LABEL[post.media]}</span>
              </div>
              <h3 class="news__post-title">{post.title}</h3>
            </a>
          ))
        }
      </div>
    </div>

    <div class="news__footer">
      <a class="btn btn--primary" href="/news">
        View All News
        <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .news {
    background: radial-gradient(
      120% 80% at 50% 0%,
      var(--cog-navy-glow) 0%,
      var(--cog-navy) 38%,
      var(--cog-navy-deep) 100%
    );
    border-top: 1px solid var(--cog-line);
    color: var(--cog-white);
  }
  .news__inner {
    padding-block: var(--space-section);
  }

  /* ---- Header ---- */
  .news__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-16);
    align-items: start;
    margin-bottom: var(--space-16);
  }
  .news__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4.4vw, 3.75rem); /* 40 → 60px */
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .news__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .news__heading-strong {
    font-weight: 700;
    color: var(--cog-white);
  }
  .news__head :global(.news__lede) {
    max-width: 790px;
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-body);
  }

  /* ---- Shared meta row ---- */
  .news__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .news__cat {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-navlink);
  }
  .news__dot {
    width: 4px;
    height: 4px;
    flex-shrink: 0;
    border-radius: 50%;
    background-color: var(--cog-muted);
  }
  .news__date {
    font-size: var(--text-sm);
    color: var(--cog-muted);
  }

  /* ---- Grid ---- */
  .news__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: var(--space-16);
    align-items: flex-start;
  }

  /* ---- Featured card ---- */
  .news__feature {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: var(--space-12);
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--cog-line);
    border-top: 3px solid var(--cog-accent);
    color: inherit;
    text-decoration: none;
  }
  .news__feature-num {
    position: absolute;
    top: -25px;
    right: var(--space-8);
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    font-size: 150px;
    line-height: 1;
    color: rgba(255, 255, 255, 0.06);
    pointer-events: none;
  }
  .news__tag {
    align-self: flex-start;
    padding: 4px 10px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--cog-accent);
    border: 1px solid var(--cog-accent);
  }
  .news__feature .news__meta {
    margin-top: var(--space-8);
  }
  .news__feature-title {
    margin-top: var(--space-4);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.875rem, 3vw, 2.625rem); /* 30 → 42px */
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--cog-white);
    text-wrap: balance;
    transition: color var(--transition);
  }
  .news__feature-excerpt {
    max-width: 560px;
    margin: var(--space-4) 0 var(--space-8);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-body);
  }
  .news__more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .news__more-icon {
    flex-shrink: 0;
    transition: transform var(--transition);
  }
  .news__feature:hover .news__more-icon {
    transform: translateX(4px);
  }
  .news__feature:hover .news__feature-title {
    color: var(--cog-cream);
  }

  /* ---- List (02/03/04) ---- */
  .news__list {
    display: flex;
    flex-direction: column;
  }
  .news__post {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-block: var(--space-8);
    border-top: 1px solid var(--cog-line);
    color: inherit;
    text-decoration: none;
  }
  .news__post-num {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    font-size: var(--text-xl);
    line-height: 1;
    color: var(--cog-accent);
  }
  .news__post-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 2vw, 1.875rem); /* 24 → 30px */
    line-height: 1.18;
    letter-spacing: -0.005em;
    color: var(--cog-white);
    text-wrap: pretty;
    transition: color var(--transition);
  }
  .news__post:hover .news__post-title {
    color: var(--cog-cream);
  }

  /* ---- Footer ---- */
  .news__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--space-14);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .news__head,
    .news__grid {
      grid-template-columns: 1fr;
    }
    .news__head {
      row-gap: var(--space-8);
    }
    .news__grid {
      row-gap: var(--space-8);
    }
  }
</style>
