---
// Homepage "About" band — two columns on paper: firm story + Notable Results
// carousel on the left, courthouse photo with brand seal + pull-quote on the right.
import { Image } from "astro:assets";
import Eyebrow from "./Eyebrow.astro";
import aboutPhoto from "../assets/about-courthouse.jpg";

const results = [
  {
    outcome: "Acquitted",
    caseName: "The Enron Trial",
    note: "Our client was the sole person acquitted in any Enron-related trial.",
  },
  {
    outcome: "Acquitted",
    caseName: "Waco / Branch Davidian",
    note: "Won acquittal for Clive Doyle on charges tied to the deaths of federal agents at the Waco siege.",
  },
  {
    outcome: "Acquitted",
    caseName: "Fraud Acquittal",
    note: "An orthopedic surgeon acquitted of all charges — wire fraud, health care fraud and insurance fraud.",
  },
  {
    outcome: "Acquitted",
    caseName: "Physician Victory",
    note: "An alternative-treatment physician acquitted of multiple charges; the rest dismissed after two trials.",
  },
  {
    outcome: "Mistrial",
    caseName: "Pharmacy Fraud Mistrial",
    note: "Charged with wire and mail fraud — the court declared a mistrial for prosecutorial misconduct after six weeks.",
  },
  {
    outcome: "Acquitted",
    caseName: "Psychiatric Fraud Victory",
    note: "In the “Spring Shadows Glenn” trial, our client was acquitted of all charges after a six-month prosecution.",
  },
];
---

<section class="about" id="about">
  <div class="container about__inner">
    <!-- Left column: story + notable results -->
    <div class="about__col">
      <Eyebrow>Texas Criminal Defense Lawyer</Eyebrow>
      <h2 class="about__title">
        <span class="about__title-lead">Four Decades of</span>
        <span class="about__title-strong">High-Profile Victories</span>
      </h2>

      <p class="about__body">
        Dan Cogdell has spent more than 40 years trying complex cases in
        courtrooms across Texas and the nation. Named one of the state’s best
        lawyers by the Texas Tribune and recognized by Texas Monthly, he has
        built a practice defined by high-profile wins in cases others deemed
        unwinnable.
      </p>
      <p class="about__body">
        His acquittal of a defendant in the Enron trial remains a landmark in
        white-collar defense, while his victory in the Waco/Branch Davidian
        prosecution cemented his reputation as a trial lawyer willing to take on
        the government at its most aggressive.
      </p>
      <p class="about__body">
        Today, the firm focuses on complex civil disputes, catastrophic personal
        injury, federal criminal defense, and government investigations — always
        with the same philosophy: prepare every case for trial, and try it to
        win.
      </p>

      <div class="about__results">
        <div class="about__results-head">
          <Eyebrow>Notable Results</Eyebrow>
          <div class="about__arrows">
            <button class="about__arrow" data-dir="prev" type="button" aria-label="Previous results">
              <svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true"><path d="M10.5 2.5L5 8l5.5 5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="about__arrow" data-dir="next" type="button" aria-label="Next results">
              <svg viewBox="0 0 16 16" width="16" height="16" fill="none" aria-hidden="true"><path d="M5.5 2.5L11 8l-5.5 5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        </div>

        <div class="about__scroller">
          {
            results.map((r) => (
              <article class="about__result">
                <span class="about__tag">{r.outcome}</span>
                <h3 class="about__result-title">{r.caseName}</h3>
                <p class="about__result-note">{r.note}</p>
              </article>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Right column: photo + seal + pull-quote -->
    <div class="about__col about__media">
      <div class="about__photo">
        <Image
          src={aboutPhoto}
          alt="Dan Cogdell walking down the courthouse steps"
          widths={[640, 960, 1280, 1584]}
          sizes="(max-width: 900px) 92vw, 45vw"
          class="about__photo-img lazy-fade"
        />
        <div class="about__seal">
          <svg viewBox="0 0 160 160" width="146" height="146" aria-hidden="true">
            <defs>
              <path id="about-seal-top" d="M 24,80 A 56,56 0 0 1 136,80" fill="none"></path>
              <path id="about-seal-bot" d="M 24,80 A 56,56 0 0 0 136,80" fill="none"></path>
            </defs>
            <circle cx="80" cy="80" r="76" fill="var(--cog-paper-card)" stroke="var(--cog-accent)" stroke-width="1.5"></circle>
            <circle cx="80" cy="80" r="67" fill="none" stroke="rgba(14, 27, 45, 0.22)" stroke-width="1"></circle>
            <text class="about__seal-arc"><textPath href="#about-seal-top" startOffset="50%" text-anchor="middle">DEFENDING TEXAS</textPath></text>
            <text class="about__seal-arc"><textPath href="#about-seal-bot" startOffset="50%" text-anchor="middle">SINCE 1983</textPath></text>
            <text x="80" y="84" text-anchor="middle" class="about__seal-num">40+</text>
            <text x="80" y="103" text-anchor="middle" class="about__seal-years">YEARS</text>
          </svg>
        </div>
      </div>

      <blockquote class="about__quote">
        <p class="about__quote-text">
          Sought-after advocates for the cases others call
          <span class="about__quote-accent"> unwinnable</span> — with
          <span class="about__quote-accent"> 40+ years</span> of courtroom
          victories behind every defense.
        </p>
      </blockquote>
    </div>
  </div>
</section>

<style>
  .about {
    background-color: var(--cog-paper);
  }
  .about__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: var(--space-16);
    align-items: start;
    padding-block: var(--space-section);
  }
  /* min-width:0 lets columns shrink below content so the results scroller and
     long text wrap/scroll internally instead of forcing horizontal overflow. */
  .about__col {
    min-width: 0;
  }

  /* ---- Heading lockup ---- */
  .about__title {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    margin-bottom: var(--space-6);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2.375rem, 4.2vw, 3.625rem); /* 38 → 58px */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .about__title-lead,
  .about__title-strong {
    display: block;
  }
  .about__title-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .about__title-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }

  /* ---- Body copy ---- */
  .about__body {
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }
  .about__body:last-of-type {
    margin-bottom: 0;
  }

  /* ---- Notable Results carousel ---- */
  .about__results {
    margin-top: var(--space-12);
  }
  .about__results-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  .about__arrows {
    display: flex;
    gap: var(--space-2);
  }
  .about__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1px solid var(--cog-accent);
    border-radius: 50%;
    background-color: transparent;
    color: var(--cog-accent);
    cursor: pointer;
    transition:
      background-color var(--transition),
      color var(--transition);
  }
  .about__arrow:hover {
    background-color: var(--cog-accent);
    color: var(--cog-white);
  }

  .about__scroller {
    display: flex;
    gap: var(--space-6);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 4px 4px 8px;
    margin-inline: -4px;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* legacy Edge */
  }
  .about__scroller::-webkit-scrollbar {
    display: none; /* Chrome, Safari */
  }
  .about__result {
    flex: 0 0 calc(50% - var(--space-3));
    scroll-snap-align: start;
    min-width: 0;
    padding: var(--space-6) var(--space-6) 26px;
    background-color: var(--cog-paper-card);
    border: 1px solid var(--cog-line-ink);
    border-top: 3px solid var(--cog-accent);
  }
  .about__tag {
    display: inline-block;
    margin-bottom: var(--space-4);
    padding: 4px 12px;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-accent);
    border: 1px solid var(--cog-accent);
    border-radius: 100px;
  }
  .about__result-title {
    margin-bottom: var(--space-3);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.375rem, 1.2rem + 0.6vw, 1.5625rem); /* 22 → 25px */
    line-height: 1.16;
    color: var(--cog-ink);
  }
  .about__result-note {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--cog-ink-muted);
  }

  /* ---- Media column ---- */
  .about__media {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }
  .about__photo {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    max-height: 660px;
  }
  .about__photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .about__seal {
    position: absolute;
    right: -18px;
    bottom: -28px;
    filter: drop-shadow(0 10px 24px rgba(14, 27, 45, 0.25));
  }
  .about__seal-arc {
    fill: var(--cog-ink);
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 2.2px;
  }
  .about__seal-num {
    fill: var(--cog-ink);
    font-family: var(--font-heading);
    font-size: 40px;
    font-weight: 700;
  }
  .about__seal-years {
    fill: var(--cog-accent);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
  }

  /* ---- Pull-quote ---- */
  .about__quote {
    position: relative;
    margin: 0;
    padding-left: 26px;
  }
  .about__quote::before {
    content: "";
    position: absolute;
    left: 0;
    top: 4px;
    width: 12px;
    height: calc(100% - 8px);
    border-left: 3px solid var(--cog-accent);
    border-top: 3px solid var(--cog-accent);
  }
  .about__quote-text {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 2.3vw, 1.9375rem); /* 24 → 31px */
    line-height: 1.28;
    letter-spacing: -0.005em;
    color: var(--cog-ink);
    text-wrap: balance;
  }
  .about__quote-accent {
    font-style: italic;
    color: var(--cog-accent);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .about__inner {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--space-16);
    }
  }
  @media (max-width: 650px) {
    .about__result {
      flex-basis: 85%;
    }
    .about__seal {
      right: 0;
      bottom: -20px;
    }
    .about__seal svg {
      width: 112px;
      height: 112px;
    }
  }
</style>

<script>
  // Arrow buttons scroll the results carousel by one card width.
  document.querySelectorAll<HTMLElement>(".about__results").forEach((root) => {
    const scroller = root.querySelector<HTMLElement>(".about__scroller");
    if (!scroller) return;
    const step = () => {
      const card = scroller.querySelector<HTMLElement>(".about__result");
      return card ? card.offsetWidth + 24 : 320;
    };
    root
      .querySelector('[data-dir="prev"]')
      ?.addEventListener("click", () =>
        scroller.scrollBy({ left: -step(), behavior: "smooth" })
      );
    root
      .querySelector('[data-dir="next"]')
      ?.addEventListener("click", () =>
        scroller.scrollBy({ left: step(), behavior: "smooth" })
      );
  });
</script>
