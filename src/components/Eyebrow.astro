---
// Shared eyebrow — small uppercase tracked label with a leading accent rule.
// The rule is always accent; `tone` sets the label color (accent on paper,
// light on dark CTA bands). The eyebrow → heading gap is owned by the parent.
interface Props {
  tone?: "accent" | "light" | "white";
  center?: boolean;
  rule?: boolean;
  class?: string;
}

const { tone = "accent", center = false, rule = true, class: className } = Astro.props;
---

<p class:list={["eyebrow", `eyebrow--${tone}`, { "eyebrow--center": center }, className]}>
  {rule && <span class="eyebrow__rule" aria-hidden="true"></span>}
  <slot />
</p>

<style>
  .eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .eyebrow--center {
    justify-content: center;
  }
  .eyebrow--accent {
    color: var(--cog-accent);
  }
  .eyebrow--light {
    color: var(--cog-navlink);
  }
  .eyebrow--white {
    color: var(--cog-white);
  }
  .eyebrow__rule {
    width: 24px;
    height: 2px;
    flex-shrink: 0;
    background-color: var(--cog-accent);
  }
</style>
