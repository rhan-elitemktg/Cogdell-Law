---
// Grid of press mentions / news. Paper-card cells with an accent top-rule wipe on
// hover (same recipe as PracticeGrid, tuned for paper). External items link out in
// a new tab with a ↗ affordance; owned posts link to /news/[slug] with an arrow.
import Eyebrow from "../Eyebrow.astro";
import { urlFor } from "../../sanity/lib/image";

type NewsMedia = "article" | "video" | "podcast";
interface NewsCard {
  _id: string;
  title: string;
  outlet: string;
  media: NewsMedia;
  summary: string;
  ctaLabel?: string | null;
  linkType?: string | null;
  externalUrl?: string | null;
  slug?: string | null;
  outletLogo?: unknown;
}

interface Props {
  items: NewsCard[];
  eyebrow?: string;
  headingLead?: string;
  headingStrong?: string;
}

const { items, eyebrow, headingLead, headingStrong } = Astro.props;
const hasHead = Boolean(eyebrow || headingLead);

// Lucide inner-paths (viewBox 0 0 24 24) + label + default action verb per medium.
const MEDIA: Record<NewsMedia, { label: string; verb: string; icon: string }> = {
  article: {
    label: "Article",
    verb: "Read more",
    icon: '<path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-6"/><path d="M10 6h8v4h-8Z"/>',
  },
  video: {
    label: "Video",
    verb: "Watch",
    icon: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m10 9 5 3-5 3Z"/>',
  },
  podcast: {
    label: "Podcast",
    verb: "Listen",
    icon: '<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/>',
  },
};

const externalIcon =
  '<path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>';
const arrowIcon = '<path d="M5 12h14M13 6l6 6-6 6"/>';
---

<section class="ngrid">
  <div class="container">
    {
      hasHead && (
        <div class="ngrid__head">
          {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
          {headingLead && (
            <h2 class="ngrid__heading">
              <span class="ngrid__heading-lead">{headingLead}</span>{" "}
              <span class="ngrid__heading-strong">{headingStrong}</span>
            </h2>
          )}
        </div>
      )
    }

    <div class="ngrid__grid">
      {
        items.map((item) => {
          const external = item.linkType === "external";
          const href = external ? item.externalUrl! : `/news/${item.slug}`;
          const media = MEDIA[item.media];
          const cta = item.ctaLabel ?? media.verb;
          return (
            <a
              class="ngrid__cell"
              href={href}
              target={external ? "_blank" : undefined}
              rel={external ? "noopener noreferrer" : undefined}
            >
              <div class="ngrid__top">
                <span class="ngrid__outlet">
                  {item.outletLogo ? (
                    <img
                      class="ngrid__outlet-logo"
                      src={urlFor(item.outletLogo).height(44).url()}
                      alt={item.outlet}
                      height={22}
                    />
                  ) : (
                    item.outlet
                  )}
                </span>
                <span class="ngrid__media">
                  <svg
                    viewBox="0 0 24 24"
                    width="14"
                    height="14"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.75"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={media.icon}
                  />
                  {media.label}
                </span>
              </div>

              <h3 class="ngrid__title">{item.title}</h3>
              <p class="ngrid__summary">{item.summary}</p>

              <span class="ngrid__cta">
                {cta}
                <svg
                  class="ngrid__cta-icon"
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={external ? externalIcon : arrowIcon}
                />
              </span>
              {external && <span class="ngrid__ext-note">Opens {item.outlet} in a new tab</span>}
            </a>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .ngrid {
    background-color: var(--cog-paper);
    padding-block: var(--space-section);
  }
  .ngrid__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
    max-width: 720px;
  }
  .ngrid__heading {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.4vw, 3rem);
    line-height: 1.06;
    letter-spacing: -0.01em;
  }
  .ngrid__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .ngrid__heading-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }

  .ngrid__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .ngrid__cell {
    position: relative;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: var(--space-8);
    background-color: var(--cog-paper-card);
    border: 1px solid var(--cog-line);
    text-decoration: none;
    cursor: pointer;
  }
  /* Accent top-rule wipe on hover. */
  .ngrid__cell::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--cog-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }
  .ngrid__cell:hover::before {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .ngrid__cell::before {
      transition: none;
    }
  }

  .ngrid__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .ngrid__outlet {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .ngrid__outlet-logo {
    width: auto;
    height: 22px;
    object-fit: contain;
  }
  .ngrid__media {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--cog-ink-muted);
  }

  .ngrid__title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.25rem, 1.1rem + 0.7vw, 1.5rem);
    line-height: 1.2;
    color: var(--cog-ink);
    text-wrap: pretty;
    transition: color var(--transition);
  }
  .ngrid__cell:hover .ngrid__title {
    color: var(--cog-accent-dark);
  }
  .ngrid__summary {
    flex: 1;
    margin: var(--space-4) 0 var(--space-6);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--cog-ink-body);
  }

  .ngrid__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .ngrid__cta-icon {
    flex-shrink: 0;
    transition: transform var(--transition);
    position: relative;
    top: -2px;
  }
  
  /* Visually hidden helper for screen readers on external links. */
  .ngrid__ext-note {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .ngrid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 650px) {
    .ngrid__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
