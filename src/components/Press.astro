---
// Homepage "As seen in" press strip — an infinite, slow marquee of outlet logos.
//
// Homepage-only, so it fetches its own content (D9). Logos live in Sanity (D6:
// "as seen in" is a marketing claim the firm updates) and are served from
// Sanity's CDN via urlFor rather than the astro:assets pipeline. Each logo is
// shown at a fixed height with object-fit: contain, so width/height only prevent
// layout shift.
import { urlFor } from "../sanity/lib/image";
import { getHomePress } from "../sanity/lib/homePage";

const logos = await getHomePress();

if (!logos?.length) {
  throw new Error(
    "No press logos found on the Home Page in Sanity.\n" +
      "Add them in the Studio at /admin → Home Page → Press, or seed them with:\n" +
      "  npx sanity exec scripts/seed-press.ts --with-user-token",
  );
}

// Displayed at 42px tall; serve 2× for retina crispness.
const LOGO_RENDER_HEIGHT = 84;
---

<section class="press" aria-label="Featured in the press">
  <div class="press__viewport">
    <ul class="press__track">
      {
        logos.map((logo) => (
          <li class="press__item">
            <img
              src={urlFor(logo.image).height(LOGO_RENDER_HEIGHT).url()}
              alt={logo.alt}
              width={logo.dimensions?.width}
              height={logo.dimensions?.height}
              loading="lazy"
              decoding="async"
              class="press__logo"
            />
          </li>
        ))
      }
      {/* Duplicate set for a seamless loop */}
      {
        logos.map((logo) => (
          <li class="press__item" aria-hidden="true">
            <img
              src={urlFor(logo.image).height(LOGO_RENDER_HEIGHT).url()}
              alt=""
              width={logo.dimensions?.width}
              height={logo.dimensions?.height}
              loading="lazy"
              decoding="async"
              class="press__logo"
            />
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .press {
    padding-block: var(--space-8);
    background-color: var(--cog-white);
    border-bottom: 1px solid var(--cog-line-ink);
  }
  .press__viewport {
    overflow: hidden;
  }
  .press__track {
    display: flex;
    align-items: center;
    width: max-content;
    margin: 0;
    padding: 0;
    list-style: none;
    animation: press-marquee 50s linear infinite;
  }
  .press:hover .press__track {
    animation-play-state: paused;
  }
  /* Spacing lives on the item (not `gap`) so each item carries its own trailing
     gap — that keeps translateX(-50%) landing exactly one set over (seamless). */
  .press__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    margin-inline-end: var(--space-16);
  }
  .press__logo {
    width: auto;
    height: 42px;
    object-fit: contain;
  }

  @keyframes press-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .press__track {
      animation: none;
    }
  }
</style>
