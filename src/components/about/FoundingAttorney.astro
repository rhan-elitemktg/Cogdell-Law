---
// Our Firm "Founding Attorney" — study portrait left, career story right.
import { Image } from "astro:assets";
import { PortableText } from "astro-portabletext";
import Eyebrow from "../Eyebrow.astro";
import BareParagraph from "../prose/BareParagraph.astro";

interface Props { eyebrow: string; headingLead: string; headingStrong: string; body: unknown }
const { eyebrow, headingLead, headingStrong, body } = Astro.props;
import portrait from "../../assets/consult-portrait.jpg";
---

<section class="founding">
  <div class="container founding__inner">
    <div class="founding__media">
      <Image
        src={portrait}
        alt="Dan Cogdell seated in the firm's study"
        widths={[640, 976]}
        sizes="(max-width: 900px) 100vw, 42vw"
        class="founding__photo lazy-fade"
      />
    </div>

    <div class="founding__body">
      <Eyebrow>{eyebrow}</Eyebrow>
      <h2 class="founding__heading">
        <span class="founding__heading-lead">{headingLead}</span>
        <span class="founding__heading-strong">{headingStrong}</span>
      </h2>
      <PortableText value={body} components={{ block: { normal: BareParagraph } }} />
      <div class="founding__actions">
        <a href="/#results" class="btn btn--primary">
          View Trial Experience
          <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .founding {
    background-color: var(--cog-white);
  }
  .founding__inner {
    display: grid;
    grid-template-columns: minmax(0, 790px) minmax(0, 640px);
    justify-content: space-between;
    column-gap: var(--space-16);
    align-items: center;
    padding-block: var(--space-section);
  }

  /* Content left, image right on desktop. DOM order stays media-first so the
     stacked mobile layout still leads with the photo (see the 900px query). */
  .founding__body {
    order: 1;
  }
  .founding__media {
    order: 2;
    align-self: stretch;
    display: flex;
  }
  .founding__photo {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    object-position: center top;
  }

  .founding__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    margin-bottom: var(--space-6);
    font-family: var(--font-heading);
    font-size: clamp(2.375rem, 4.2vw, 3.625rem); /* 38 → 58px */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .founding__heading-lead,
  .founding__heading-strong {
    display: block;
  }
  .founding__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .founding__heading-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }

  .founding__body :global(p) {
    max-width: 660px;
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }
  .founding__actions {
    margin-top: var(--space-6);
  }

  @media (max-width: 900px) {
    .founding__inner {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--space-8);
    }
    .founding__media {
      order: 1;
    }
    .founding__body {
      order: 2;
    }
    .founding__photo {
      max-height: 480px;
    }
  }
</style>
