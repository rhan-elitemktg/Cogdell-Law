---
// Our Firm origin story — the motocross track tale, photo left / story right,
// with a four-milestone timeline below.
import { Image } from "astro:assets";
import Eyebrow from "../Eyebrow.astro";
import motoPhoto from "../../assets/cogdell-motorcycle.jpg";

const milestones = [
  {
    key: "1970s",
    title: "Rio Bravo",
    desc: "A Houston motocross track — where a young rider first crossed paths with the legendary Richard “Racehorse” Haynes.",
  },
  {
    key: "Age 25",
    title: "Hired by a Legend",
    desc: "After an unorthodox interview, Haynes hired the tenacious Dan Cogdell on the spot.",
  },
  {
    key: "4 Years",
    title: "Youngest Partner",
    desc: "Cogdell became the youngest partner in the history of Haynes' firm.",
  },
  {
    key: "Today",
    title: "Cogdell Law Firm",
    desc: "The firm of choice for the cases other lawyers call unwinnable.",
  },
];
---

<section class="origin">
  <div class="container">
    <div class="origin__grid">
      <div class="origin__media">
        <Image
          src={motoPhoto}
          alt="Dan Cogdell with a vintage motocross bike"
          widths={[640, 960, 1489]}
          sizes="(max-width: 900px) 100vw, 45vw"
          class="origin__photo lazy-fade"
        />
      </div>

      <div class="origin__body">
        <div class="origin__head">
          <Eyebrow>Where It All Began</Eyebrow>
          <h2 class="origin__heading">
            <span class="origin__heading-lead">A Motocross Track</span>
            <span class="origin__heading-strong"> and a Legend.</span>
          </h2>
        </div>
        <p>
          In the gritty expanse of a Houston motocross track in the 1970s, known
          as Rio Bravo, a fellow rider caught Mr. Cogdell's attention — it was
          Richard “Racehorse” Haynes, a legal juggernaut who once tried 163 DWI
          cases consecutively, resulting in a mere two convictions. About a year
          later, Haynes took on the John Hill case, the basis for the book
          <em>Blood and Money</em>.
        </p>
        <p>
          It inspired Mr. Cogdell so much that he attended law school with the
          sole intention of working alongside Haynes. Despite a
          less-than-stellar undergraduate record, determination led to academic
          excellence at South Texas College of Law — and, ultimately, an
          interview with Haynes himself.
        </p>
        <p>
          The interview was unorthodox. Rather than deliver the expected mock
          closing argument, Cogdell recounted Haynes' distinctive style on the
          motocross track, jolting his memory and earning an invitation for
          drinks. His rationale was simple: if they were to collaborate on
          grueling trials, they might as well gauge their camaraderie first.
        </p>
        <p>
          More than a mentor, Haynes became a father figure — imparting lessons
          that transcended legal strategy and reached into the core of human
          connection with juries, bailiffs, and clerks alike. When everything is
          on the line and liberty is at risk, hire the best.
        </p>
      </div>
    </div>

    <dl class="origin__milestones">
      {
        milestones.map((m) => (
          <div class="origin__mile">
            <dt class="origin__mile-key">{m.key}</dt>
            <dd class="origin__mile-body">
              <h3 class="origin__mile-title">{m.title}</h3>
              <p class="origin__mile-desc">{m.desc}</p>
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .origin {
    background-color: var(--cog-paper);
  }
  .origin .container {
    padding-block: var(--space-section);
  }

  /* ---- Head (sits above the story copy in the right column) ---- */
  .origin__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4); /* standard eyebrow → heading gap */
    margin-bottom: var(--space-6);
  }
  .origin__heading {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2.375rem, 4.2vw, 3.625rem); /* 38 → 58px */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .origin__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .origin__heading-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }

  /* ---- Story grid ---- */
  .origin__grid {
    display: grid;
    grid-template-columns: minmax(0, 720px) minmax(0, 790px);
    justify-content: space-between;
    column-gap: var(--space-16);
    align-items: center;
  }
  .origin__media {
    align-self: stretch;
    display: flex;
  }
  .origin__photo {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    object-position: center;
    border: 1px solid var(--cog-line-ink);
  }
  .origin__body p {
    max-width: 660px;
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }
  .origin__body p:last-child {
    margin-bottom: 0;
  }

  /* ---- Milestones ---- */
  .origin__milestones {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    margin: var(--space-12) 0 0;
    background-color: var(--cog-line-ink);
    border: 1px solid var(--cog-line-ink);
  }
  .origin__mile {
    padding: var(--space-6);
    background-color: var(--cog-paper-card);
  }
  .origin__mile-key {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    font-size: var(--text-lg);
    color: var(--cog-accent);
  }
  .origin__mile-body {
    margin: var(--space-3) 0 0;
  }
  .origin__mile-title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-xl);
    line-height: 1.15;
    color: var(--cog-ink);
  }
  .origin__mile-desc {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--cog-ink-muted);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .origin__grid {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--space-8);
    }
    .origin__photo {
      max-height: 520px;
    }
    .origin__milestones {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 650px) {
    .origin__milestones {
      grid-template-columns: 1fr;
    }
  }
</style>
