---
// Our Firm origin story — the motocross track tale, photo left / story right,
// with a four-milestone timeline below.
import { Image } from "astro:assets";
import { PortableText } from "astro-portabletext";
import Eyebrow from "../Eyebrow.astro";
import BareParagraph from "../prose/BareParagraph.astro";

interface Milestone { _key?: string; key: string; title: string; desc: string }
interface Props { eyebrow: string; headingLead: string; headingStrong: string; body: unknown; milestones: Milestone[] }
const { eyebrow, headingLead, headingStrong, body, milestones } = Astro.props;
import motoPhoto from "../../assets/cogdell-motorcycle.jpg";

---

<section class="origin">
  <div class="container">
    <div class="origin__grid">
      <div class="origin__media">
        <Image
          src={motoPhoto}
          alt="Dan Cogdell with a vintage motocross bike"
          widths={[640, 960, 1489]}
          sizes="(max-width: 900px) 100vw, 45vw"
          class="origin__photo lazy-fade"
        />
      </div>

      <div class="origin__body">
        <div class="origin__head">
          <Eyebrow>{eyebrow}</Eyebrow>
          <h2 class="origin__heading">
            <span class="origin__heading-lead">{headingLead}</span>
            <span class="origin__heading-strong"> {headingStrong}</span>
          </h2>
        </div>
        <PortableText value={body} components={{ block: { normal: BareParagraph } }} />
        </div>
    </div>

    <dl class="origin__milestones">
      {
        milestones.map((m) => (
          <div class="origin__mile">
            <dt class="origin__mile-key">{m.key}</dt>
            <dd class="origin__mile-body">
              <h3 class="origin__mile-title">{m.title}</h3>
              <p class="origin__mile-desc">{m.desc}</p>
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .origin {
    background-color: var(--cog-paper);
  }
  .origin .container {
    padding-block: var(--space-section);
  }

  /* ---- Head (sits above the story copy in the right column) ---- */
  .origin__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4); /* standard eyebrow → heading gap */
    margin-bottom: var(--space-6);
  }
  .origin__heading {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2.375rem, 4.2vw, 3.625rem); /* 38 → 58px */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .origin__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .origin__heading-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }

  /* ---- Story grid ---- */
  .origin__grid {
    display: grid;
    grid-template-columns: minmax(0, 790px) minmax(0, 720px);
    justify-content: space-between;
    column-gap: var(--space-16);
    align-items: center;
  }
  /* Content left, image right on desktop. DOM order stays media-first so the
     stacked mobile layout still leads with the photo (see the 900px query). */
  .origin__body {
    order: 1;
  }
  .origin__media {
    order: 2;
    align-self: stretch;
    display: flex;
  }
  .origin__photo {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    object-position: center;
    border: 1px solid var(--cog-line-ink);
  }
  .origin__body :global(p) {
    max-width: 660px;
    margin-bottom: var(--space-4);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }
  .origin__body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* ---- Milestones ---- */
  .origin__milestones {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    margin: var(--space-12) 0 0;
    background-color: var(--cog-line-ink);
    border: 1px solid var(--cog-line-ink);
  }
  .origin__mile {
    padding: var(--space-6);
    background-color: var(--cog-paper-card);
  }
  .origin__mile-key {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    font-size: var(--text-lg);
    color: var(--cog-accent);
  }
  .origin__mile-body {
    margin: var(--space-3) 0 0;
  }
  .origin__mile-title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--text-xl);
    line-height: 1.15;
    color: var(--cog-ink);
  }
  .origin__mile-desc {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--cog-ink-muted);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .origin__grid {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--space-8);
    }
    .origin__media {
      order: 1;
    }
    .origin__body {
      order: 2;
    }
    .origin__photo {
      max-height: 520px;
    }
    .origin__milestones {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 650px) {
    .origin__milestones {
      grid-template-columns: 1fr;
    }
  }
</style>
