---
// Renders block-based content: paragraphs (with optional inline links), bullet
// lists (items may also carry inline links), and blockquotes.
//
// Styling lives in global.css under "Prose", shared with the Portable Text
// renderers so CMS body copy and this legacy Block[] copy look identical.
// This component is replaced by <PortableText> in Phase 5 (D3).
import type { Block, Inline } from "../../data/practice-areas";

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;

const isString = (value: unknown): value is string => typeof value === "string";
---

{
  blocks.map((block) => {
    if ("quote" in block) {
      return <blockquote class="prose__quote">{block.quote}</blockquote>;
    }
    if ("ul" in block) {
      return (
        <ul class="prose__list">
          {block.ul.map((item) => (
            <li>
              {isString(item)
                ? item
                : item.map((seg) =>
                    isString(seg) ? (
                      seg
                    ) : (
                      <a class="prose__link" href={seg.href}>
                        {seg.text}
                      </a>
                    ),
                  )}
            </li>
          ))}
        </ul>
      );
    }
    return (
      <p class="prose__p">
        {isString(block.p)
          ? block.p
          : block.p.map((seg: Inline) =>
              isString(seg) ? (
                seg
              ) : (
                <a class="prose__link" href={seg.href}>
                  {seg.text}
                </a>
              ),
            )}
      </p>
    );
  })
}

