---
// Parameterized card grid of linked practice areas / sub-topics. Navy cells with
// an accent top-rule wipe on hover (same recipe as the homepage PracticeAreas).
import Eyebrow from "../Eyebrow.astro";

interface Item {
  title: string;
  summary?: string;
  href: string;
  icon?: string; // Lucide inner-path
}

interface Props {
  items: Item[];
  eyebrow?: string;
  headingLead?: string;
  headingStrong?: string;
}

const { items, eyebrow, headingLead, headingStrong } = Astro.props;
const hasHead = Boolean(eyebrow || headingLead);
---

<section class="pgrid">
  <div class="container">
    {
      hasHead && (
        <div class="pgrid__head">
          {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
          {headingLead && (
            <h2 class="pgrid__heading">
              <span class="pgrid__heading-lead">{headingLead}</span>{" "}
              <span class="pgrid__heading-strong">{headingStrong}</span>
            </h2>
          )}
        </div>
      )
    }

    <div class="pgrid__grid">
      {
        items.map((item) => (
          <a class="pgrid__cell" href={item.href}>
            {item.icon && (
              <svg
                class="pgrid__icon"
                viewBox="0 0 24 24"
                width="28"
                height="28"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={item.icon}
              />
            )}
            <div class="pgrid__cell-body">
              <h3 class="pgrid__cell-title">{item.title}</h3>
              {item.summary && <p class="pgrid__cell-desc">{item.summary}</p>}
            </div>
            <span class="pgrid__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .pgrid {
    background-color: var(--cog-paper);
    padding-block: var(--space-section);
  }
  .pgrid__head {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
    max-width: 720px;
  }
  .pgrid__heading {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.4vw, 3rem);
    line-height: 1.06;
    letter-spacing: -0.01em;
  }
  .pgrid__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .pgrid__heading-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }

  .pgrid__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background-color: var(--cog-navy-glow);
    border: 1px solid var(--cog-navy-glow);
  }
  .pgrid__cell {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 240px;
    padding: var(--space-8);
    background-color: var(--cog-navy-deep);
    text-decoration: none;
  }
  .pgrid__cell::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--cog-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }
  .pgrid__cell:hover::before {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .pgrid__cell::before {
      transition: none;
    }
  }
  .pgrid__icon {
    color: var(--cog-accent);
    margin-bottom: var(--space-6);
  }
  .pgrid__cell-body {
    flex: 1;
  }
  .pgrid__cell-title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.375rem, 1.2rem + 0.6vw, 1.625rem);
    line-height: 1.15;
    color: var(--cog-white);
  }
  .pgrid__cell-desc {
    margin: var(--space-3) 0 0;
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--cog-body);
  }
  .pgrid__arrow {
    margin-top: var(--space-6);
    color: var(--cog-accent);
    transition: transform var(--transition);
  }
  .pgrid__cell:hover .pgrid__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .pgrid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 650px) {
    .pgrid__grid {
      grid-template-columns: 1fr;
    }
    .pgrid__cell {
      min-height: 0;
    }
  }
</style>
