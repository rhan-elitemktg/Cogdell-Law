---
// Breadcrumb trail for nested pages. Practice Areas / … — no Home crumb; Home
// is always one click away in the header nav.
import type { Crumb } from "../../lib/breadcrumb";

interface Props {
  trail: Crumb[];
}

const { trail } = Astro.props;
---

<nav class="crumbs" aria-label="Breadcrumb">
  <div class="container crumbs__inner">
    {
      trail.map((crumb, i) => (
        <Fragment>
          {i > 0 && (
            <span class="crumbs__sep" aria-hidden="true">/</span>
          )}
          {i === trail.length - 1 ? (
            <span class="crumbs__current" aria-current="page">
              {crumb.title}
            </span>
          ) : crumb.href ? (
            <a class="crumbs__link" href={crumb.href}>
              {crumb.title}
            </a>
          ) : (
            <span class="crumbs__link">{crumb.title}</span>
          )}
        </Fragment>
      ))
    }
  </div>
</nav>

<style>
  .crumbs {
    background-color: var(--cog-paper);
    border-bottom: 1px solid var(--cog-line-ink);
    overflow-x: scroll;
  }
  .crumbs__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: var(--space-2);
    padding-block: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    max-width: 800px;
  }
  .crumbs__link {
    color: var(--cog-ink-muted);
    text-decoration: none;
    transition: color var(--transition);
  }
  .crumbs__link:hover {
    color: var(--cog-accent);
  }
  .crumbs__sep {
    color: var(--cog-line-ink);
  }
  .crumbs__current {
    color: var(--cog-ink);
    font-weight: 600;
  }
</style>
