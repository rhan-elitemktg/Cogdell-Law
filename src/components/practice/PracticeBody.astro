---
// Long-form practice-area content: an optional intro, then h2 sections. Single
// constrained prose column for readability.
import Blocks from "./Blocks.astro";
import type { Block, PracticeSection } from "../../data/practice-areas";

interface Props {
  intro?: Block[];
  sections?: PracticeSection[];
}

const { intro, sections } = Astro.props;
---

<section class="pbody">
  <div class="container pbody__inner">
    {intro && intro.length > 0 && (
      <div class="pbody__lead">
        <Blocks blocks={intro} />
      </div>
    )}

    {
      sections?.map((section) => (
        <div class="pbody__section">
          <h2 class="pbody__heading">{section.heading}</h2>
          <Blocks blocks={section.blocks} />
        </div>
      ))
    }
  </div>
</section>

<style>
  .pbody {
    background-color: var(--cog-paper);
  }
  .pbody__inner {
    max-width: 900px;
    padding-block: var(--space-section);
  }
  .pbody__lead {
    font-size: var(--text-lg);
  }
  .pbody__lead :global(.prose__p) {
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--cog-ink);
  }
  .pbody__section {
    margin-top: var(--space-14);
  }
  .pbody__heading {
    margin: 0 0 var(--space-6);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.625rem, 2.4vw, 2.25rem);
    line-height: 1.15;
    color: var(--cog-ink);
  }
</style>
