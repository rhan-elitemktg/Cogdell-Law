---
// Interior page hero — full-bleed photo with a left-to-right navy scrim,
// eyebrow + two-tone title + lede, and CTA buttons via the default slot.
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Eyebrow from "./Eyebrow.astro";

interface Props {
  eyebrow: string;
  titleLead?: string; // italic cream line — omit for a single-tone title
  titleStrong: string; // bold white line
  lede?: string;
  image?: ImageMetadata; // omit for a plain navy hero (no photo)
  imageAlt?: string;
  imagePosition?: string;
}

const {
  eyebrow,
  titleLead,
  titleStrong,
  lede,
  image,
  imageAlt = "",
  imagePosition = "center 30%",
} = Astro.props;
---

<section class:list={["page-hero", !image && "page-hero--plain"]}>
  {
    image && (
      <Image
        src={image}
        alt={imageAlt}
        widths={[900, 1200, 1584]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        class="page-hero__bg"
      />
    )
  }
  {image && <div class="page-hero__overlay" aria-hidden="true" />}

  <div class="container page-hero__inner">
    <div class="page-hero__content">
      <Eyebrow>{eyebrow}</Eyebrow>
      <h1 class="page-hero__title">
        {titleLead && <span class="page-hero__title-lead">{titleLead}</span>}
        <span class="page-hero__title-strong">{titleStrong}</span>
      </h1>
      {lede && <p class="page-hero__lede">{lede}</p>}
      <div class="page-hero__actions">
        <slot />
      </div>
    </div>
  </div>
</section>

<style define:vars={{ imagePosition }}>
  .page-hero {
    position: relative;
    overflow: hidden;
    background-color: var(--cog-navy-deep);
    color: var(--cog-white);
  }
  /* Imageless variant: a subtle navy glow instead of a photo + scrim. */
  .page-hero--plain {
    background: radial-gradient(
      125% 120% at 15% 0%,
      var(--cog-navy) 0%,
      var(--cog-navy-deep) 55%
    );
  }
  /* Extra bottom room so an overlapping section (e.g. contact cards) clears the lede. */
  .page-hero--plain .page-hero__inner {
    padding-bottom: calc(var(--space-section) + var(--space-12));
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--imagePosition);
  }
  /* Darken from the left so the text column reads over the photo. */
  .page-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      90deg,
      rgba(7, 16, 29, 0.96) 0%,
      rgba(7, 16, 29, 0.88) 42%,
      rgba(7, 16, 29, 0.6) 78%,
      rgba(7, 16, 29, 0.4) 100%
    );
  }

  .page-hero__inner {
    position: relative;
    z-index: 2;
    padding-block: var(--space-section);
  }
  .page-hero__content {
    max-width: 720px;
  }

  .page-hero__title {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 4.4vw, 3.75rem); /* 40 → 60px */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .page-hero__title-lead,
  .page-hero__title-strong {
    display: block;
  }
  .page-hero__title-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-cream);
  }
  .page-hero__title-strong {
    font-weight: 700;
    color: var(--cog-white);
  }

  .page-hero__lede {
    max-width: 560px;
    margin-top: var(--space-6);
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--cog-white);
  }

  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  .page-hero__actions:empty {
    display: none;
  }
</style>
