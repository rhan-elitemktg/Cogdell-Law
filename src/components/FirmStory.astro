---
// Homepage "Why Cogdell" band — full-bleed courthouse-steps photo with a
// bottom-solid scrim and centered firm story + CTA.
import { Image } from "astro:assets";
import { PortableText } from "astro-portabletext";
import { proseComponents } from "./prose/components";
import Eyebrow from "./Eyebrow.astro";
import FirmStoryBody from "./firm/FirmStoryBody.astro";
import bgPhoto from "../assets/firm-steps.jpg";
import { getHomeFirmStory } from "../sanity/lib/homePage";

// Homepage-only, so it fetches its own content (D9). The courthouse photo is
// art direction and stays in the repo (D6).
const story = await getHomeFirmStory();

if (!story) {
  throw new Error(
    "No Firm Story found on the Home Page in Sanity.\n" +
      "Add it in the Studio at /admin → Home Page, or seed it with:\n" +
      "  npx sanity exec scripts/seed-firm-story.ts --with-user-token",
  );
}
---

<section class="firm-story">
  <Image
    src={bgPhoto}
    alt=""
    widths={[1200, 1376]}
    sizes="100vw"
    class="firm-story__bg lazy-fade"
  />
  <div class="firm-story__overlay" aria-hidden="true"></div>

  <div class="firm-story__inner">
    <Eyebrow center rule={false} tone="white">{story.eyebrow}</Eyebrow>
    <h2 class="firm-story__heading">
      <span class="firm-story__heading-lead">{story.headingLead}</span>
      <br/>
      <span class="firm-story__heading-strong"> {story.headingStrong}</span>
    </h2>

    <PortableText value={story.body} components={{
          ...proseComponents,
          block: { ...proseComponents.block, normal: FirmStoryBody },
        }} />

    <div class="firm-story__actions">
      <a href={story.cta?.href} class="btn btn--primary">
        {story.cta?.label}
        <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .firm-story {
    position: relative;
    overflow: hidden;
    background-color: var(--cog-navy-deep);
    color: var(--cog-white);
  }

  .firm-story__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  /* Show the photo up top, then settle into solid navy where the copy sits. */
  .firm-story__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(7, 16, 29, 0.5) 0%,
      rgba(7, 16, 29, 0.7) 28%,
      rgba(7, 16, 29, 0.92) 52%,
      var(--cog-navy-deep) 78%
    );
  }

  .firm-story__inner {
    position: relative;
    z-index: 2;
    max-width: 980px;
    margin-inline: auto;
    padding-block: var(--space-section);
    padding-inline: var(--space-6);
    text-align: center;
  }

  .firm-story__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    font-size: clamp(2.375rem, 4.4vw, 3.75rem); /* 38 → 60px */
    line-height: 1.04;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }
  .firm-story__heading-lead {
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2.75rem, 5.3vw, 4.5rem); /* 44 → 72px, larger than the bold line */
    color: var(--cog-cream);
    line-height: 1.25;
  }
  .firm-story__heading-strong {
    font-weight: 700;
    color: var(--cog-white);
  }

  .firm-story__inner :global(.firm-story__body) {
    max-width: 760px;
    margin-inline: auto;
    margin-top: var(--space-6);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-white);
  }
  .firm-story__body:first-of-type {
    margin-top: var(--space-8);
  }

  .firm-story__actions {
    margin-top: var(--space-8);
  }
</style>

