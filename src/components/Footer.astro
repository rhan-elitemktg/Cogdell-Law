---
// Site footer — brand + contact + map + nav, then a legal bar. Rendered on every page.
import { Image } from "astro:assets";
import logo from "../assets/cogdell-logo-light.png";
import { getFirmDetails } from "../sanity/lib/firmDetails";

const firm = await getFirmDetails();
const phone = firm?.phone ?? "713-426-2244";
const phoneHref = `tel:+1${phone.replace(/[^0-9]/g, "")}`;
const year = new Date().getFullYear();

const mapQuery = "Cogdell Law Firm, 712 Main St Ste 2400, Houston, TX 77002";
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(mapQuery)}&z=15&output=embed`;

const practiceLinks = [
  { label: "Federal Criminal Cases", href: "/practice-areas/federal-criminal-cases" },
  { label: "Federal Crimes Investigations", href: "/practice-areas/federal-criminal-cases/federal-crimes-investigations" },
  { label: "Fraud & White Collar Crimes", href: "/practice-areas/fraud-white-collar-crimes" },
  { label: "Health Care Fraud Defense", href: "/practice-areas/health-care-fraud-defense" },
];
const firmLinks = [
  { label: "Attorneys", href: "/attorneys" },
  { label: "Our Firm", href: "/our-firm" },
  { label: "Trial Experience", href: "/trial-experience" },
  { label: "News", href: "/news" },
];

const socials = [
  { label: "Facebook", href: "#", path: '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>' },
  { label: "X", href: "#", path: '<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>' },
  { label: "LinkedIn", href: "#", path: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-12h4v1.6A6 6 0 0 1 16 8z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer__inner">
      <!-- Brand + contact -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="Cogdell Law Firm — home">
          <Image src={logo} alt="Cogdell Law Firm" densities={[1, 2]} />
        </a>
        <p class="footer__tagline">
          Trusted Texas counsel for high-stakes federal and white collar
          criminal defense — legal triumphs are a tradition.
        </p>

        <ul class="footer__contact">
          <li class="footer__contact-item">
            <span class="footer__contact-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
            </span>
            <div>
              <span class="footer__contact-label">Call</span>
              <a class="footer__contact-value" href={phoneHref}>{phone}</a>
            </div>
          </li>
          <li class="footer__contact-item">
            <span class="footer__contact-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
            </span>
            <div>
              <span class="footer__contact-label">Email</span>
              <a class="footer__contact-value" href="mailto:info@cogdell-law.com">info@cogdell-law.com</a>
            </div>
          </li>
          <li class="footer__contact-item">
            <span class="footer__contact-icon">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" /></svg>
            </span>
            <div>
              <span class="footer__contact-label">Office</span>
              <span class="footer__contact-value">712 Main St., Suite 2400 <br/>Houston, TX 77002</span>
            </div>
          </li>
        </ul>

        <ul class="footer__social">
          {
            socials.map((s) => (
              <li>
                <a class="footer__social-link" href={s.href} aria-label={s.label}>
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true" set:html={s.path} />
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Map -->
      <div class="footer__map">
        <iframe
          class="footer__map-frame"
          src={mapSrc}
          title="Map to Cogdell Law Firm, 712 Main St Suite 2400, Houston"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>

      <!-- Nav -->
      <nav class="footer__nav" aria-label="Footer">
        <div class="footer__nav-group">
          <h2 class="footer__nav-title">Practice</h2>
          <ul>
            {practiceLinks.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer__nav-group">
          <h2 class="footer__nav-title">Firm</h2>
          <ul>
            {firmLinks.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer__bottom">
      <div class="footer__legal">
        <p>© {year} Cogdell Law Firm. All rights reserved.</p>
        <nav class="footer__legal-links" aria-label="Legal">
          <a href="/privacy">Privacy Policy | </a>
          <a href="/disclaimer">Disclaimer</a>
        </nav>
      </div>
      <a
        class="footer__credit-link"
        href="https://www.elitelegalmarketing.com/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Website by Elite Legal Marketing"
      >
        <img
          class="footer__credit"
          src="/elite-white.svg"
          alt="Elite Legal Marketing"
          width="90"
          height="35"
          loading="lazy"
        />
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--cog-navy-deep);
    color: var(--cog-white);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 2.4fr) minmax(0, 1fr);
    column-gap: var(--space-16);
    padding-block-start: var(--space-section);
  }

  /* ---- Brand ---- */
  .footer__logo {
    display: inline-flex;
    line-height: 0;
  }
  .footer__logo :global(img) {
    height: 5.5rem; /* 88px */
    width: auto;
  }
  .footer__tagline {
    max-width: 380px;
    margin-top: var(--space-8);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--cog-body);
  }

  /* ---- Contact ---- */
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin: var(--space-8) 0 0;
    padding: 0;
    list-style: none;
  }
  .footer__contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .footer__contact-icon {
    flex-shrink: 0;
    color: var(--cog-accent);
  }
  .footer__contact-label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .footer__contact-value {
    display: block;
    margin-top: 2px;
    font-size: var(--text-base);
    color: var(--cog-white);
    text-decoration: none;
    transition: color var(--transition);
  }
  a.footer__contact-value:hover {
    color: var(--cog-cream);
  }

  /* ---- Social ---- */
  .footer__social {
    display: flex;
    gap: var(--space-6);
    margin: var(--space-8) 0 0;
    padding: 0;
    list-style: none;
  }
  .footer__social-link {
    display: inline-flex;
    color: var(--cog-navlink);
    transition: color var(--transition);
  }
  .footer__social-link:hover {
    color: var(--cog-accent);
  }

  /* ---- Map ---- */
  .footer__map {
    aspect-ratio: 7 / 5;
    overflow: hidden;
    border: 1px solid var(--cog-line);
  }
  .footer__map-frame {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* ---- Nav ---- */
  .footer__nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .footer__nav-title {
    margin: 0 0 var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .footer__nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .footer__nav a {
    font-size: var(--text-base);
    color: var(--cog-navlink);
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer__nav a:hover {
    color: var(--cog-white);
  }

  /* ---- Legal bar ---- */
  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    margin-top: var(--space-16);
    padding-block: var(--space-8);
    border-top: 1px solid var(--cog-line);
  }
  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }
  .footer__bottom p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--cog-muted);
  }
  .footer__legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    font-size: var(--text-sm);
    transition: color var(--transition);
  }
  .footer__legal-links a {
    text-decoration: none;
    color: var(--cog-muted);
  }
  .footer__legal-links a:hover {
    color: var(--cog-white);
  }
  .footer__credit-link {
    display: inline-flex;
    line-height: 0;
    opacity: 0.85;
    transition: opacity var(--transition);
  }
  .footer__credit-link:hover {
    opacity: 1;
  }
  .footer__credit {
    height: 45px;
    width: auto;
  }

  /* ---- Responsive ---- */
  @media (max-width: 1024px) {
    .footer__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      row-gap: var(--space-12);
    }
    /* Map spans the full width under the brand + nav row */
    .footer__map {
      grid-column: 1 / -1;
      order: 3;
    }
  }
  @media (max-width: 650px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }
    .footer__bottom {
      flex-direction: column;
    }
  }
</style>
