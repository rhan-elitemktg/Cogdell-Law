---
// Homepage full-bleed "Litigation Boutique" band — team photo with a bottom
// scrim; eyebrow + lockup on the left, positioning statement + link on the right.
import { Image } from "astro:assets";
import Eyebrow from "./Eyebrow.astro";
import teamPhoto from "../assets/team-group.png";
---

<section class="video-band">
  <div class="video-band__media">
    <Image
      src={teamPhoto}
      alt="The attorneys of Cogdell Law Firm"
      widths={[900, 1300]}
      sizes="100vw"
      class="video-band__bg lazy-fade"
    />
    <div class="video-band__overlay" aria-hidden="true"></div>
  </div>

  <div class="container video-band__inner">
    <div class="video-band__lead">
      <Eyebrow>A Litigation Boutique</Eyebrow>
      <h2 class="video-band__heading">
        <span class="video-band__heading-italic">Built for the Highest Stakes —</span>
        <span class="video-band__heading-bold">Civil and Criminal.</span>
      </h2>
    </div>

    <div class="video-band__aside">
      <p class="video-band__body">
        We are trial lawyers. We handle complex civil disputes alongside white
        collar defense and serious criminal matters — because the same
        preparation and courtroom ability that wins in federal criminal court
        wins in complex civil litigation.
      </p>
      <a href="/our-firm" class="video-band__more">
        About the Firm
        <svg class="video-band__more-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .video-band {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: clamp(560px, 72vh, 760px);
    overflow: hidden;
    background-color: var(--cog-navy-deep);
    color: var(--cog-white);
  }

  /* Full-bleed media layer (behind the copy) on desktop. */
  .video-band__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .video-band__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  /* Darken from the bottom up so the photo reads clear while the copy stays legible.
     The bottom 20px is fully solid navy before it feathers, so the band blends
     seamlessly into the solid CTA bar below. */
  .video-band__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(7, 16, 29, 1) 0,
      rgba(7, 16, 29, 1) 20px,
      rgba(7, 16, 29, 0.6) 36%,
      rgba(7, 16, 29, 0) 68%,
      rgba(7, 16, 29, 0.15) 100%
    );
  }

  .video-band__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: var(--space-16);
    align-items: end;
    padding-block-end: var(--space-16);
  }

  /* ---- Heading lockup ---- */
  .video-band__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .video-band__heading-italic,
  .video-band__heading-bold {
    display: block;
    font-size: clamp(2.375rem, 4.4vw, 3.75rem); /* 38 → 60px */
  }
  .video-band__heading-italic {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-cream);
  }
  .video-band__heading-bold {
    margin-top: 4px;
    font-weight: 700;
    color: var(--cog-white);
  }

  /* ---- Aside (body + link) ---- */
  .video-band__aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 560px;
    justify-self: end;
  }
  .video-band__body {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-white);
  }
  .video-band__more {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-accent);
    text-decoration: none;
  }
  .video-band__more:hover {
    color: var(--cog-accent);
  }
  .video-band__more-icon {
    flex-shrink: 0;
    transition: transform var(--transition);
  }
  .video-band__more:hover .video-band__more-icon {
    transform: translateX(4px);
  }

  /* ---- Responsive ---- */
  /* On tablet/mobile, stack the full (uncropped) photo above the copy so every
     attorney stays visible, with the image bottom fading into the navy block. */
  @media (max-width: 900px) {
    .video-band {
      display: block;
      min-height: 0;
    }
    .video-band__media {
      position: relative;
      inset: auto;
    }
    .video-band__bg {
      position: relative;
      inset: auto;
      height: auto; /* natural aspect — shows the whole team */
    }
    .video-band__overlay {
      inset: auto 0 0 0;
      height: 60%;
      background: linear-gradient(
        180deg,
        rgba(7, 16, 29, 0) 0%,
        rgba(7, 16, 29, 0.55) 45%,
        rgba(7, 16, 29, 0.9) 78%,
        rgba(7, 16, 29, 1) 100%
      );
    }
    .video-band__inner {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--space-8);
      padding-block: var(--space-8) var(--space-16);
    }
    .video-band__aside {
      justify-self: start;
      max-width: none;
    }
  }
</style>
