---
// Contact page "reach us" cards — Call / Email / Visit. The row overlaps up
// into the PageHero above (transparent section over the paper body background).
const methods = [
  {
    label: "Call Us Directly",
    value: "713-426-2244",
    sub: "Available Mon–Fri, 8am–6pm CT",
    href: "tel:7134262244",
    external: false,
    icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>',
  },
  {
    label: "Email Us",
    value: "info@cogdell-law.com",
    sub: "We respond within one business day",
    href: "mailto:info@cogdell-law.com",
    external: false,
    icon: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/>',
  },
  {
    label: "Visit Our Office",
    value: "712 Main St., Suite 2400",
    sub: "Houston, TX 77002",
    href: "https://www.google.com/maps/place/Cogdell+Law+Firm/@29.7589819,-95.3664168,1203m/data=!3m2!1e3!4b1!4m6!3m5!1s0x8640bf236fa77c17:0xf198f5cfa4418201!8m2!3d29.7589819!4d-95.3638365!16s%2Fg%2F1tdblcl3?entry=ttu&g_ep=EgoyMDI2MDcwOC4wIKXMDSoASAFQAw%3D%3D",
    external: true,
    icon: '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>',
  },
];
---

<section class="contact-methods">
  <div class="container">
    <div class="contact-methods__grid">
      {
        methods.map((m) => (
          <a
            class="cmethod"
            href={m.href}
            target={m.external ? "_blank" : undefined}
            rel={m.external ? "noopener noreferrer" : undefined}
          >
            <span class="cmethod__icon">
              <svg
                viewBox="0 0 24 24"
                width="22"
                height="22"
                fill="none"
                stroke="currentColor"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={m.icon}
              />
            </span>
            <span class="cmethod__label">{m.label}</span>
            <span class="cmethod__value">{m.value}</span>
            <span class="cmethod__sub">{m.sub}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Transparent section pulled up so the cards straddle the navy/paper edge;
     the paper ground behind them comes from the page body background. */
  .contact-methods {
    position: relative;
    z-index: 1;
    margin-top: calc(-1 * var(--space-12));
    padding-bottom: var(--space-section);
    border-bottom: 1px solid var(--cog-line);
  }
  .contact-methods__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .cmethod {
    display: flex;
    flex-direction: column;
    padding: var(--space-8);
    background-color: var(--cog-white);
    box-shadow: 0 22px 48px rgba(7, 16, 29, 0.1);
    text-decoration: none;
    transition:
      transform var(--transition),
      box-shadow var(--transition);
  }
  .cmethod:hover {
    transform: translateY(-4px);
    box-shadow: 0 28px 58px rgba(7, 16, 29, 0.14);
  }
  .cmethod__icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-8);
    color: var(--cog-accent);
    background-color: var(--cog-navy-deep);
  }
  .cmethod__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .cmethod__value {
    margin-top: var(--space-3);
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: 1.15;
    color: var(--cog-ink);
    word-break: break-word;
  }
  .cmethod__sub {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--cog-ink-muted);
  }

  @media (max-width: 860px) {
    .contact-methods {
      margin-top: calc(-1 * var(--space-6));
    }
    .contact-methods__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
