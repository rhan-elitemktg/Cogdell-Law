---
// "Schedule Your Consultation" band — contact form + photo. Renders on 13 pages.
//
// The copy is one shared Consult record with an optional per-page override (D13);
// pages that have a document pass `pageId` so their override can win. Dynamic
// routes have no document and get the shared default.
//
// The photo stays a prop: it's art direction (D6), and /our-firm and /contact use
// their own. The form's labels, placeholders and button text stay in code — only
// the fineprint and thank-you are editable, since they're client-facing legal
// statements rather than UI chrome.
import { Image } from "astro:assets";
import { PortableText } from "astro-portabletext";
import type { ImageMetadata } from "astro";
import Eyebrow from "./Eyebrow.astro";
import { proseComponents } from "./prose/components";
import ConsultBody from "./consult/ConsultBody.astro";
import defaultPhoto from "../assets/consult-portrait.jpg";
import { getConsult } from "../sanity/lib/consult";

interface Props {
  /** Document id of the host page, when it has one — enables its override. */
  pageId?: string;
  photo?: ImageMetadata;
  photoAlt?: string;
}

const {
  pageId,
  photo = defaultPhoto,
  photoAlt = "Dan Cogdell seated in the firm's study",
} = Astro.props;

const consult = await getConsult(pageId);

if (!consult) {
  throw new Error(
    "No Consult content found in Sanity.\n" +
      "Add it in the Studio at /admin → Consult, or seed it with:\n" +
      "  npx sanity exec scripts/seed-consult.ts --with-user-token",
  );
}
---

<section class="consult" id="contact">
  <div class="container consult__inner">
    <div class="consult__panel">
      <Eyebrow>{consult.eyebrow}</Eyebrow>
      <h2 class="consult__heading">
        <span class="consult__heading-lead">{consult.headingLead}</span>
        <span class="consult__heading-strong">{consult.headingStrong}</span>
      </h2>
      <PortableText
        value={consult.body}
        components={{
          ...proseComponents,
          block: { ...proseComponents.block, normal: ConsultBody },
        }}
      />

      <form class="consult__form">
        <div class="consult__field">
          <label class="consult__label" for="consult-name">Full Name</label>
          <input class="consult__input" id="consult-name" name="name" type="text" placeholder="Jane Doe" required />
        </div>
        <div class="consult__field">
          <label class="consult__label" for="consult-phone">Phone</label>
          <input class="consult__input" id="consult-phone" name="phone" type="tel" placeholder="(713) 000-0000" />
        </div>
        <div class="consult__field consult__field--wide">
          <label class="consult__label" for="consult-email">Email</label>
          <input class="consult__input" id="consult-email" name="email" type="email" placeholder="you@email.com" required />
        </div>
        <div class="consult__field consult__field--wide">
          <label class="consult__label" for="consult-message">How can we help?</label>
          <textarea class="consult__input consult__textarea" id="consult-message" name="message" rows="4" placeholder="Briefly describe your situation"></textarea>
        </div>
        <p class="consult__fineprint">{consult.fineprint}</p>
        <div class="consult__actions">
          <button class="btn btn--primary" type="submit">
            Request Consultation
            <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </button>
        </div>
      </form>

      <p class="consult__thanks" hidden>{consult.thankYou}</p>
    </div>

    <div class="consult__media">
      <Image
        src={photo}
        alt={photoAlt}
        widths={[640, 976]}
        sizes="(max-width: 900px) 100vw, 45vw"
        class="consult__photo lazy-fade"
      />
    </div>
  </div>
</section>

<style>
  .consult {
    background-color: var(--cog-paper);
    overflow: hidden;
  }
  .consult__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: var(--space-16);
    align-items: center;
    padding-block: var(--space-section);
  }

  /* ---- Copy ---- */
  .consult__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    font-size: clamp(2.125rem, 3.4vw, 3rem); /* 34 → 48px */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .consult__heading-lead,
  .consult__heading-strong {
    display: block;
  }
  .consult__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .consult__heading-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }
  .consult__panel :global(.consult__body) {
    max-width: 560px;
    margin: var(--space-4) 0 var(--space-8);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }

  /* ---- Form ---- */
  .consult__form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  .consult__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .consult__field--wide {
    grid-column: 1 / -1;
  }
  .consult__label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cog-ink-muted);
  }
  .consult__input {
    width: 100%;
    height: 60px;
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--cog-ink);
    background-color: var(--cog-white);
    border: 1px solid var(--cog-line-ink);
    border-radius: 0;
    transition: border-color var(--transition);
  }
  .consult__input::placeholder {
    color: var(--cog-ink-muted);
  }
  .consult__input:focus {
    outline: none;
    border-color: var(--cog-accent);
  }
  .consult__textarea {
    height: auto;
    min-height: 120px;
    resize: vertical;
  }
  .consult__fineprint {
    grid-column: 1 / -1;
    margin: 0;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: var(--text-base);
    color: var(--cog-ink-muted);
  }
  .consult__actions {
    grid-column: 1 / -1;
    margin-top: var(--space-2);
  }
  .consult__thanks {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--cog-ink);
  }

  /* ---- Media ---- */
  .consult__media {
    align-self: stretch;
    display: flex;
  }
  .consult__photo {
    width: 100%;
    height: 100%;
    min-height: 560px;
    object-fit: cover;
    object-position: center;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .consult__inner {
      grid-template-columns: 1fr;
      row-gap: var(--space-12);
    }
    /* Photo first is nicer on stacked mobile */
    .consult__media {
      order: -1;
    }
    .consult__photo {
      min-height: 420px;
    }
  }
  @media (max-width: 650px) {
    /* Stack every field full-width on phones (Full Name + Phone no longer split). */
    .consult__form {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // No backend yet — confirm inline on submit (native validation still gates it).
  const form = document.querySelector<HTMLFormElement>(".consult__form");
  const thanks = document.querySelector<HTMLElement>(".consult__thanks");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    form.hidden = true;
    if (thanks) thanks.hidden = false;
  });
</script>
