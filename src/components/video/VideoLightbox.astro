---
// Global video lightbox. Any element on the page with `data-video-id="<wistia id>"`
// opens this modal and loads that Wistia video; the iframe is only injected on
// open and cleared on close (so nothing loads until a video is clicked, and audio
// stops when it closes). Rendered once in the Layout.
---

<dialog class="vlb" aria-label="Video player">
  <button type="button" class="vlb__close" aria-label="Close video">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
  </button>
  <div class="vlb__frame"></div>
</dialog>

<style>
  .vlb {
    width: min(1040px, 92vw);
    max-width: 92vw;
    /* Restore the UA-default centering that global.css's `* { margin: 0 }` wipes out. */
    margin: auto;
    padding: 0;
    border: 0;
    background: transparent;
    overflow: visible;
    color: var(--cog-white);
  }
  .vlb::backdrop {
    background-color: rgba(7, 16, 29, 0.92);
  }
  .vlb__frame {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    background-color: #000;
    background-size: cover;
    background-position: center;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.55);
  }
  .vlb__frame :global(iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .vlb__close {
    position: absolute;
    /* Above the iframe, which covers the frame and comes later in the DOM
       (matters on mobile, where the button sits inside the video's corner). */
    z-index: 2;
    top: calc(-1 * (44px + var(--space-3)));
    right: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--cog-white);
    background-color: var(--cog-accent);
    border: 0;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
    transition: background-color var(--transition), transform var(--transition);
  }
  .vlb__close:hover {
    background-color: var(--cog-accent-dark);
    transform: scale(1.06);
  }
  .vlb__close:focus-visible {
    outline: 2px solid var(--cog-white);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .vlb__close {
      transition: background-color var(--transition);
    }
    .vlb__close:hover {
      transform: none;
    }
  }
</style>

<script>
  const dialog = document.querySelector<HTMLDialogElement>(".vlb");
  const frame = dialog?.querySelector<HTMLDivElement>(".vlb__frame");
  const closeBtn = dialog?.querySelector<HTMLButtonElement>(".vlb__close");

  const embed = (id: string) =>
    `https://fast.wistia.net/embed/iframe/${id}?autoPlay=true&playsinline=true`;

  function open(id: string, poster?: string | null) {
    if (!dialog || !frame) return;
    // Paint the poster immediately so there's a real frame (not black) while the
    // Wistia player boots and buffers; the iframe covers it once it renders.
    frame.style.backgroundImage = poster ? `url("${poster}")` : "";
    frame.innerHTML = `<iframe src="${embed(id)}" allow="autoplay; fullscreen" allowfullscreen title="Video player"></iframe>`;
    dialog.showModal();
  }

  function close() {
    if (dialog?.open) dialog.close();
  }

  // Delegate: any [data-video-id] trigger opens the lightbox (progressive
  // enhancement — triggers keep an href fallback for the no-JS case).
  document.addEventListener("click", (e) => {
    const trigger = (e.target as HTMLElement)?.closest<HTMLElement>("[data-video-id]");
    if (!trigger) return;
    const id = trigger.getAttribute("data-video-id");
    if (!id) return;
    e.preventDefault();
    open(id, trigger.getAttribute("data-video-poster"));
  });

  closeBtn?.addEventListener("click", close);
  // Click on the backdrop (outside the frame/close button) closes.
  dialog?.addEventListener("click", (e) => {
    if (e.target === dialog) close();
  });
  // Native ESC / close: clear the iframe so playback stops.
  dialog?.addEventListener("close", () => {
    if (!frame) return;
    frame.innerHTML = "";
    frame.style.backgroundImage = "";
  });
</script>
