---
// Selling-points / stats bar. Presentational: the caller owns the content, since
// this is shared between the homepage (from Sanity) and /our-firm (its own set).
// The layout expects exactly four — see the flex-basis / nth-child rules below.
interface Props {
  points: { value: string; label: string }[];
}

const { points } = Astro.props;
---

<section class="selling-points">
  <div class="container">
    <div class="inner">
      {
        points.map((point) => (
          <div class="selling-point">
            <span class="selling-point__rule" aria-hidden="true"></span>
            <span class="selling-point__value">{point.value}</span>
            <span class="selling-point__label">{point.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .selling-points {
    background-color: var(--cog-navy);
    
    .inner {
      display: flex;
      justify-content: space-between;
    }
    
    .selling-point {
      padding: var(--space-12) var(--space-8);
      border-right: 1px solid var(--cog-navy-glow);
      flex: 1;
      display: flex;
      flex-direction: column;
      flex-basis: 25%;
      &:last-child {
        border-right: 0;
      }
    }
    
    .selling-point__rule {
      width: 34px;
      height: 2px;
      background-color: var(--cog-accent);
      margin-bottom: var(--space-4);
    }
    
    .selling-point__value {
      color: var(--cog-white);
      font-family: var(--font-heading);
      font-size: var(--text-3xl);
      font-weight: bold;
    }
    
    .selling-point__label {
      font-size: var(--text-xs);
      text-transform: uppercase;
      font-weight: bold;
      color: var(--cog-cream);
      letter-spacing: 1px;
    }
    
    @media (max-width: 1200px) {
      .container {
        padding: 0;
      }
      .inner {
        flex-wrap: wrap;
      }
      .selling-point {
        flex-basis: 50%;
        border-right: 0;
        padding: var(--space-8) var(--space-8);
        &:first-child {
          border-right: 1px solid var(--cog-navy-glow);
          border-bottom: 1px solid var(--cog-navy-glow);
        }
        &:nth-child(2) {
          border-bottom: 1px solid var(--cog-navy-glow);
        }
        &:nth-child(3) {
          border-right: 1px solid var(--cog-navy-glow);
        }
      }
    }
    
  }
</style>
