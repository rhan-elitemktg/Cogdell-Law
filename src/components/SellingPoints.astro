---
// Selling-points / stats bar. Defaults to the homepage set; pages can pass
// their own `points`. Static for now (can move to Sanity later).
interface Props {
  points?: { value: string; label: string }[];
}

const defaultPoints = [
  { value: "40+", label: "Years of Trial Experience" },
  { value: "Nationwide", label: "Federal & State Courts" },
  { value: "Elite", label: "Top 2% of Trial Lawyers" },
  { value: "Confidential", label: "Free Case Evaluation" },
];

const { points = defaultPoints } = Astro.props;
---

<section class="selling-points">
  <div class="container">
    <div class="inner">
      {
        points.map((point) => (
          <div class="selling-point">
            <span class="selling-point__rule" aria-hidden="true"></span>
            <span class="selling-point__value">{point.value}</span>
            <span class="selling-point__label">{point.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .selling-points {
    background-color: var(--cog-navy);
    border-top: 1px solid var(--cog-line);
    border-bottom: 1px solid var(--cog-line);
    
    .inner {
      display: flex;
      justify-content: space-between;
    }
    
    .selling-point {
      padding: var(--space-12) var(--space-8);
      border-right: 1px solid var(--cog-line);
      flex: 1;
      display: flex;
      flex-direction: column;
      flex-basis: 25%;
      &:last-child {
        border-right: 0;
      }
    }
    
    .selling-point__rule {
      width: 34px;
      height: 2px;
      background-color: var(--cog-accent);
      margin-bottom: var(--space-4);
    }
    
    .selling-point__value {
      color: var(--cog-white);
      font-family: var(--font-heading);
      font-size: var(--text-3xl);
      font-weight: bold;
    }
    
    .selling-point__label {
      font-size: var(--text-xs);
      text-transform: uppercase;
      font-weight: bold;
      color: var(--cog-cream);
      letter-spacing: 1px;
    }
    
    @media (max-width: 1200px) {
      .container {
        padding: 0;
      }
      .inner {
        flex-wrap: wrap;
      }
      .selling-point {
        flex-basis: 50%;
        border-right: 0;
        padding: var(--space-8) var(--space-4);
        &:first-child {
          border-right: 1px solid var(--cog-line);
          border-bottom: 1px solid var(--cog-line);
        }
        &:nth-child(2) {
          border-bottom: 1px solid var(--cog-line);
        }
        &:nth-child(3) {
          border-right: 1px solid var(--cog-line);
        }
      }
    }
    
  }
</style>
