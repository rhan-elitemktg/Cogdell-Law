---
import { PortableText } from "astro-portabletext";
import { proseComponents } from "./prose/components";
import Eyebrow from "./Eyebrow.astro";
import CtaBarBody from "./cta/CtaBarBody.astro";
import { getCtaBar } from "../sanity/lib/ctaBar";

// Site-wide CTA bar — three-up on desktop: eyebrow + heading, supporting copy,
// and a button. Renders on ~43 pages.
//
// Self-fetches rather than taking content props: it's the same everywhere, so
// nine callers passing identical data would be nine chances to drift. Pages that
// have their own document pass `pageId` so their optional override can win (D13);
// dynamic routes have no document and simply get the shared default.
interface Props {
  /** Document id of the host page, when it has one — enables its override. */
  pageId?: string;
}
const { pageId } = Astro.props;

const bar = await getCtaBar(pageId);

if (!bar) {
  throw new Error(
    "No CTA Bar content found in Sanity.\n" +
      "Add it in the Studio at /admin → CTA Bar, or seed it with:\n" +
      "  npx sanity exec scripts/seed-cta-bar.ts --with-user-token",
  );
}
---

<section class="ctabar">
  <div class="container ctabar__inner">
    <div class="ctabar__lead">
      <Eyebrow tone="light">{bar.eyebrow}</Eyebrow>
      <h2 class="ctabar__heading">
        <span class="ctabar__heading-lead">{bar.headingLead}</span> {bar.headingRest}
      </h2>
    </div>

    <PortableText value={bar.body} components={{
          ...proseComponents,
          block: { ...proseComponents.block, normal: CtaBarBody },
        }} />

    <div class="ctabar__action">
      <a href={bar.cta?.href} class="btn btn--light">
        {bar.cta?.label}
        <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .ctabar {
    background-color: var(--cog-navy-deep);
    border-top: 1px solid var(--cog-line);
    color: var(--cog-white);
  }
  .ctabar__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) auto;
    column-gap: var(--space-16);
    align-items: center;
    padding-block: var(--space-16);
  }

  .ctabar__heading {
    margin-top: var(--space-4); /* standard eyebrow → heading gap */
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.875rem, 3vw, 2.75rem); /* 30 → 44px */
    line-height: 1.04;
    letter-spacing: -0.01em;
    color: var(--cog-white);
  }
  .ctabar__heading-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-cream);
  }

  /* Emitted by CtaBarBody.astro (a Portable Text renderer), so it carries no
     scoping attribute of its own — see F14. The scoped .ctabar__inner parent
     bounds the :global. */
  .ctabar__inner :global(.ctabar__body) {
    max-width: 520px;
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-body);
  }

  .ctabar__action {
    justify-self: end;
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .ctabar__inner {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--space-8);
      align-items: start;
    }
    .ctabar__action {
      justify-self: stretch;
    }
  }
</style>
