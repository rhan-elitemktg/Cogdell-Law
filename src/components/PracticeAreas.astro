---
// Homepage "Practice Areas" band — light paper section with a navy card grid.
// Icon-only cards (no photos). Static for now (can move to Sanity later).

// Lucide-style icon inner-paths (viewBox 0 0 24 24), rendered inline via set:html.
const icons: Record<string, string> = {
  briefcase:
    '<rect x="3" y="7" width="18" height="13" rx="1"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="M3 12h18"/>',
  users:
    '<path d="M16 19v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="3"/><path d="M22 19v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  layers:
    '<path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 12 10 5 10-5"/><path d="m2 17 10 5 10-5"/>',
  columns:
    '<path d="M3 21h18"/><path d="M5 21V10"/><path d="M9 21V10"/><path d="M15 21V10"/><path d="M19 21V10"/><path d="M2 10 12 4l10 6"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>',
  doc: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/>',
};

const practiceAreas = [
  {
    icon: "briefcase",
    title: "Complex Civil Litigation",
    desc: "Commercial disputes, business torts, high-value plaintiff and defense work in state and federal courts.",
  },
  {
    icon: "users",
    title: "Complex Personal Injury",
    desc: "Serious injury and wrongful death — catastrophic, high-value cases where the stakes demand real trial experience.",
  },
  {
    icon: "layers",
    title: "White Collar Defense",
    desc: "Fraud, health care fraud, securities violations, financial crimes — federal and state.",
  },
  {
    icon: "columns",
    title: "Federal Criminal Defense",
    desc: "Indictments, federal trials, and appeals before district courts and circuit courts of appeals.",
  },
  {
    icon: "search",
    title: "Government Investigations",
    desc: "Grand jury matters, DOJ and FBI inquiries, regulatory enforcement actions, and agency investigations.",
  },
  {
    icon: "doc",
    title: "State Trials & Appeals",
    desc: "Felony defense in Texas courts, post-conviction relief, and federal and state appellate work.",
  },
];
---

<section class="practice">
  <div class="container">
    <div class="practice__head">
      <div class="practice__head-left">
        <p class="practice__eyebrow">
          <span class="practice__eyebrow-rule" aria-hidden="true"></span>
          Practice Areas
        </p>
        <h2 class="practice__heading">
          <span class="practice__heading-lead">What We</span>
          <span class="practice__heading-strong"> Try.</span>
        </h2>
      </div>
      <div class="practice__head-right">
        <p class="practice__desc">
          We handle the full range of disputes that demand genuine courtroom
          ability — complex civil litigation, personal injury, white collar
          defense, federal criminal matters, and high-stakes state court trials.
          Our clients come to us when the other side has deep resources, the
          stakes are real, and the case needs to be tried.
        </p>
      </div>
    </div>

    <div class="practice__grid">
      {
        practiceAreas.map((area) => (
          <div class="practice__cell">
            <svg
              class="practice__icon"
              viewBox="0 0 24 24"
              width="30"
              height="30"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={icons[area.icon]}
            />
            <div class="practice__cell-body">
              <h3 class="practice__cell-title">{area.title}</h3>
              <p class="practice__cell-desc">{area.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .practice {
    background-color: var(--cog-paper);
  }

  /* ---- Header ---- */
  .practice__head {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-16);
    align-items: start;
    padding-block: var(--space-section) var(--space-12);
  }

  .practice__head-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-4); /* standard eyebrow → heading gap */
  }

  .practice__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .practice__eyebrow-rule {
    width: 24px;
    height: 2px;
    background-color: var(--cog-accent);
    flex-shrink: 0;
  }

  .practice__heading {
    margin: 0;
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2.375rem, 4.4vw, 3.75rem); /* 38 → 60px */
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--cog-ink);
  }
  .practice__heading-strong {
    font-weight: 700;
  }

  .practice__head-right {
    display: flex;
  }

  .practice__desc {
    margin: 0;
    max-width: 750px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }

  /* ---- Card grid ---- */
  .practice__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-bottom: var(--space-section);
    background-color: var(--cog-navy-glow);
    border: 1px solid var(--cog-navy-glow);
  }

  .practice__cell {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 300px;
    padding: var(--space-12);
    background-color: var(--cog-navy-deep);
  }
  /* Accent bar that wipes across the top edge on hover (3px brand rule). */
  .practice__cell::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--cog-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition);
  }
  .practice__cell:hover::before {
    transform: scaleX(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .practice__cell::before {
      transition: none;
    }
  }

  .practice__icon {
    color: var(--cog-accent);
  }

  .practice__cell-body {
    margin-top: var(--space-14); /* the deliberate icon → title gap */
  }

  .practice__cell-title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(1.5rem, 1.36rem + 0.6vw, 1.75rem); /* 24 → 28px */
    line-height: 1.1;
    color: var(--cog-white);
  }

  .practice__cell-desc {
    margin-top: var(--space-3);
    max-width: 420px;
    font-size: var(--text-sm);
    line-height: 1.65;
    color: var(--cog-body);
  }

  /* ---- Responsive ---- */
  @media (max-width: 900px) {
    .practice__head {
      grid-template-columns: 1fr;
      row-gap: var(--space-8);
    }
    .practice__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 650px) {
    .practice__grid {
      grid-template-columns: 1fr;
    }
    .practice__cell {
      min-height: 0;
      padding: var(--space-8);
    }
    .practice__cell-body {
      margin-top: var(--space-8);
    }
  }
</style>
