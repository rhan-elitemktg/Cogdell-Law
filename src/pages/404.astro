---
import Layout from "../layouts/Layout.astro";
import Eyebrow from "../components/Eyebrow.astro";

const quickLinks = [
  { label: "Practice Areas", href: "/practice-areas" },
  { label: "Our Attorneys", href: "/attorneys" },
  { label: "Trial Experience", href: "/trial-experience" },
  { label: "Contact", href: "/contact" },
];
---

<Layout
  title="Page Not Found"
  description="The page you're looking for can't be found. Explore the Cogdell Law Firm site or get in touch."
  seo={{ noIndex: true }}
>
  <section class="notfound">
    <div class="container notfound__inner">
      <span class="notfound__code" aria-hidden="true">404</span>
      <Eyebrow>Page Not Found</Eyebrow>
      <h1 class="notfound__title">
        <span class="notfound__title-lead">This page has</span>
        <span class="notfound__title-strong">gone missing.</span>
      </h1>
      <p class="notfound__lede">
        The page you're looking for may have moved, been renamed, or never
        existed. Let's get you back on track.
      </p>

      <div class="notfound__actions">
        <a href="/" class="btn btn--primary">
          Back to Home
          <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
        <a href="/contact" class="btn btn--ghost">
          Contact Us
          <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
        </a>
      </div>

      <nav class="notfound__links" aria-label="Popular pages">
        <span class="notfound__links-label">Or try one of these:</span>
        <ul>
          {
            quickLinks.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    position: relative;
    overflow: hidden;
    background: radial-gradient(
      125% 120% at 15% 0%,
      var(--cog-paper-card) 0%,
      var(--cog-paper) 55%
    );
    color: var(--cog-ink);
  }
  .notfound__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    min-height: 62vh;
    justify-content: center;
    padding-block: var(--space-section);
    max-width: 720px;
  }
  /* Oversized watermark numeral behind the content. */
  .notfound__code {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(9rem, 28vw, 20rem);
    line-height: 1;
    color: rgba(14, 27, 45, 0.05);
    pointer-events: none;
    user-select: none;
  }
  .notfound__title {
    margin-top: var(--space-4);
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.04;
    letter-spacing: -0.01em;
  }
  .notfound__title-lead,
  .notfound__title-strong {
    display: block;
  }
  .notfound__title-lead {
    font-style: italic;
    font-weight: 500;
    color: var(--cog-gold);
  }
  .notfound__title-strong {
    font-weight: 700;
    color: var(--cog-ink);
  }
  .notfound__lede {
    max-width: 520px;
    margin-top: var(--space-6);
    font-size: var(--text-lg);
    line-height: 1.7;
    color: var(--cog-ink-body);
  }
  .notfound__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
  /* Ink-outline secondary button for the light background. */
  .notfound__actions .btn--ghost {
    color: var(--cog-ink);
    border-color: var(--cog-ink);
  }
  .notfound__actions .btn--ghost:hover {
    color: var(--cog-ink);
    border-color: var(--cog-ink);
    background-color: rgba(14, 27, 45, 0.04);
  }
  .notfound__links {
    margin-top: var(--space-12);
  }
  .notfound__links-label {
    display: block;
    margin-bottom: var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cog-accent);
  }
  .notfound__links ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .notfound__links a {
    font-size: var(--text-base);
    color: var(--cog-ink-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color var(--transition), border-color var(--transition);
  }
  .notfound__links a:hover {
    color: var(--cog-ink);
    border-bottom-color: var(--cog-accent);
  }
</style>
