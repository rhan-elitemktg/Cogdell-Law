---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import NewsGrid from "../../components/news/NewsGrid.astro";
import CtaBar from "../../components/CtaBar.astro";
import Consult from "../../components/Consult.astro";
import { news } from "../../data/news";
import heroImage from "../../assets/firm-steps.jpg";
---

<Layout
  title="News"
  description="Cogdell Law Firm in the news — press coverage, interviews, and podcast appearances from high-profile, high-stakes cases across Texas and nationally."
>
  <PageHero
    eyebrow="News"
    titleLead="Cogdell Law Firm"
    titleStrong="In the News."
    image={heroImage}
    lede="Our attorneys are known throughout Texas and nationally for handling high-profile, high-stakes cases — work that has been covered by local, national, and global media."
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <NewsGrid
    items={news}
    eyebrow="Press & Media"
    headingLead="In the"
    headingStrong="Headlines."
  />

  <CtaBar />
  <Consult />
</Layout>
