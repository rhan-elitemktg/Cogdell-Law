---
import { getPageHero } from "../../sanity/lib/pageHero";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import NewsGrid from "../../components/news/NewsGrid.astro";
import CtaBar from "../../components/CtaBar.astro";
import Consult from "../../components/Consult.astro";
import { getAllNews, getNewsGridHeader } from "../../sanity/lib/news";
import heroImage from "../../assets/firm-steps.jpg";

const news = await getAllNews();
const gridHeader = await getNewsGridHeader();

if (!news.length || !gridHeader) {
  throw new Error(
    "No news items or grid header found in Sanity.\n" +
      "Seed them with: npx sanity exec scripts/seed-news.ts --with-user-token",
  );
}

const hero = await getPageHero("newsPage");
if (!hero) {
  throw new Error("No hero found for newsPage. Seed: npx sanity exec scripts/seed-page-heroes.ts --with-user-token");
}
---

<Layout
  title="News"
  description="Cogdell Law Firm in the news — press coverage, interviews, and podcast appearances from high-profile, high-stakes cases across Texas and nationally."
>
  <PageHero
    eyebrow={hero.eyebrow}
    titleLead={hero.titleLead}
    titleStrong={hero.titleStrong}
    image={heroImage}
    lede={hero.lede ?? ""}
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <NewsGrid
    items={news}
    eyebrow={gridHeader.eyebrow}
    headingLead={gridHeader.headingLead}
    headingStrong={gridHeader.headingStrong}
  />

  <CtaBar />
  <Consult pageId="newsPage" />
</Layout>
