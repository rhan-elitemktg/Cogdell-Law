---
// Owned news article at /news/[slug]. Builds only for items with linkType
// "article" (external mentions link straight out and never reach here).
import { PortableText } from "astro-portabletext";
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/practice/Breadcrumb.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBar from "../../components/CtaBar.astro";
import Consult from "../../components/Consult.astro";
import { proseComponents } from "../../components/prose/components";
import { getNewsItem, getOwnedNewsSlugs } from "../../sanity/lib/news";
import type { Crumb } from "../../lib/breadcrumb";

export async function getStaticPaths() {
  const slugs = await getOwnedNewsSlugs();
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const item = await getNewsItem(slug!);

if (!item) {
  throw new Error(`No news article found in Sanity for slug "${slug}".`);
}

const trail: Crumb[] = [{ title: "News", href: "/news" }, { title: item.title }];
const description = item.summary ?? `${item.title} — Cogdell Law Firm.`;
---

<Layout title={item.title} description={description}>
  <Breadcrumb trail={trail} />

  <PageHero
    eyebrow={item.outlet}
    titleStrong={item.title}
    align="center"
    contentMaxWidth="700px"
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <section class="news-article">
    <div class="container news-article__body">
      <PortableText value={item.body} components={proseComponents} />
    </div>
  </section>

  <CtaBar />
  <Consult />
</Layout>

<style>
  .news-article__body {
    max-width: 760px;
    padding-block: var(--space-section);
  }
</style>
