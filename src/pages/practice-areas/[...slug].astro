---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/practice/Breadcrumb.astro";
import PageHero from "../../components/PageHero.astro";
import ProseBody from "../../components/prose/ProseBody.astro";
import PracticeGrid from "../../components/practice/PracticeGrid.astro";
import PracticeFaqs from "../../components/practice/PracticeFaqs.astro";
import CtaBar from "../../components/CtaBar.astro";
import Consult from "../../components/Consult.astro";
import { getPracticeAreaPaths } from "../../sanity/lib/practiceAreas";
import { PRACTICE_AREA_ICONS } from "../../lib/practiceAreaIcons";

export async function getStaticPaths() {
  return getPracticeAreaPaths();
}

const { node, trail, children } = Astro.props;

const childItems = (children ?? []).map((c: any) => ({
  title: c.title,
  summary: c.summary,
  href: c.href,
  icon: c.icon ? PRACTICE_AREA_ICONS[c.icon] : undefined,
}));

const description = node.lede ?? `${node.title} — Cogdell Law Firm.`;

// The opening line (lede) leads the content body, exactly as before.
// The lede is its own field (meta description + card summary) and also opens the
// body, exactly as before the intro/sections merge.
const ledeBlock = node.lede
  ? [{ _type: "block", _key: "lede", style: "normal", markDefs: [], children: [{ _type: "span", _key: "ledes", text: node.lede, marks: [] }] }]
  : [];
const bodyValue = [...ledeBlock, ...(node.body ?? [])];
---

<Layout title={node.title} description={description}>
  <Breadcrumb trail={trail} />

  <PageHero
    eyebrow="Practice Areas"
    titleStrong={node.heroTitle}
    align="center"
    contentMaxWidth="700px"
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <ProseBody body={bodyValue} />

  {node.faqs && node.faqs.length > 0 && <PracticeFaqs faqs={node.faqs} />}

  {
    childItems.length > 0 && (
      <PracticeGrid
        items={childItems}
        eyebrow="Explore"
        headingLead="Topics We"
        headingStrong="Handle."
      />
    )
  }

  <CtaBar />
  <Consult />
</Layout>
