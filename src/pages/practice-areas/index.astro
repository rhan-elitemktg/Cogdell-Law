---
import { getPageHero } from "../../sanity/lib/pageHero";
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import PracticeGrid from "../../components/practice/PracticeGrid.astro";
import CtaBar from "../../components/CtaBar.astro";
import Consult from "../../components/Consult.astro";
import { getTopLevelPracticeAreas } from "../../sanity/lib/practiceAreas";
import { PRACTICE_AREA_ICONS } from "../../lib/practiceAreaIcons";
import heroImage from "../../assets/firm-steps.jpg";

const topAreas = await getTopLevelPracticeAreas();
if (!topAreas.length) {
  throw new Error(
    "No practice areas found in Sanity.\n" +
      "Seed with: npx sanity exec scripts/seed-practice-areas-tree.ts --with-user-token",
  );
}

// A closing "get in touch" card fills the grid's last cell (5 areas leave one
// empty in a 3-col grid) and gives an easy path to the consult form.
const gridCards = [
  ...topAreas.map((a) => ({
    title: a.title,
    summary: a.summary,
    href: a.href,
    icon: a.icon ? PRACTICE_AREA_ICONS[a.icon] : undefined,
  })),
  {
    title: "Not Sure Where You Fit?",
    summary:
      "Every case is different. Reach out for a confidential consultation and we'll help you understand your options.",
    href: "#contact",
    icon: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>',
  },
];

const hero = await getPageHero("practiceAreasPage");
if (!hero) {
  throw new Error("No hero found for practiceAreasPage. Seed: npx sanity exec scripts/seed-page-heroes.ts --with-user-token");
}
---

<Layout
  title="Practice Areas"
  description="Health care fraud, federal criminal defense, white collar crimes, and appeals. For four decades, Cogdell Law Firm has tried the high-stakes cases other firms turn away."
>
  <PageHero
    eyebrow={hero.eyebrow}
    titleLead={hero.titleLead}
    titleStrong={hero.titleStrong}
    image={heroImage}
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <PracticeGrid
    items={gridCards}
    eyebrow="Our Focus"
    headingLead="Areas of"
    headingStrong="Practice."
  />

  <CtaBar />
  <Consult pageId="practiceAreasPage" />
</Layout>
