---
import Layout from "../../layouts/Layout.astro";
import PageHero from "../../components/PageHero.astro";
import PracticeGrid from "../../components/practice/PracticeGrid.astro";
import CtaBar from "../../components/CtaBar.astro";
import Consult from "../../components/Consult.astro";
import { topLevelCards } from "../../data/practice-areas";
---

<Layout
  title="Practice Areas"
  description="Health care fraud, federal criminal defense, white collar crimes, and appeals. For four decades, Cogdell Law Firm has tried the high-stakes cases other firms turn away."
>
  <PageHero
    eyebrow="Practice Areas"
    titleLead="Experienced Federal Criminal Defense"
    titleStrong="When The Stakes Are High"
    lede=""
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call 713-426-2244
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <PracticeGrid
    items={topLevelCards}
    eyebrow="Our Focus"
    headingLead="Areas of"
    headingStrong="Practice."
  />

  <CtaBar />
  <Consult />
</Layout>
