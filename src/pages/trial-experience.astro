---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import TrialResults from "../components/TrialResults.astro";
import PracticeAreas from "../components/PracticeAreas.astro";
import CtaBar from "../components/CtaBar.astro";
import Consult from "../components/Consult.astro";
import heroImage from "../assets/firm-steps.jpg";
---

<Layout
  title="Trial Experience"
  description="From Enron to the Branch Davidian trial to the Texas Attorney General, Dan Cogdell has defended and won the cases the nation was watching. Not settlements. Verdicts."
>
  <PageHero
    eyebrow="Trial Experience"
    titleLead="A Legacy of"
    titleStrong="Legal Victories."
    lede="From Enron to the Branch Davidian trial to the Texas Attorney General, Dan Cogdell has defended and won the cases the nation was watching. Not settlements. Verdicts."
    image={heroImage}
    imageAlt="The attorneys of Cogdell Law Firm ascending the courthouse steps"
    imagePosition="center 35%"
  >
    <a href="#contact" class="btn btn--primary">
      Schedule Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="/attorneys" class="btn btn--outline">
      Meet Our Attorneys
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <TrialResults />
  <PracticeAreas background="card" />
  <CtaBar />
  <Consult />
</Layout>
