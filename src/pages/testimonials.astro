---
import { getPageHero } from "../sanity/lib/pageHero";
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import TestimonialsWall from "../components/TestimonialsWall.astro";
import PracticeAreas from "../components/PracticeAreas.astro";
import CtaBar from "../components/CtaBar.astro";
import Consult from "../components/Consult.astro";
import heroImage from "../assets/firm-steps.jpg";
import { getPracticeAreasBand } from "../sanity/lib/practiceAreasBand";

// This page holds its own copy of the band, separate from the Home Page.
const practiceAreas = await getPracticeAreasBand("testimonialsPage");

if (!practiceAreas) {
  throw new Error(
    "No Practice Areas band found on the Testimonials Page in Sanity.\n" +
      "Add it in the Studio at /admin → Testimonials Page, or seed it with:\n" +
      "  npx sanity exec scripts/seed-practice-areas.ts --with-user-token",
  );
}

const hero = await getPageHero("testimonialsPage");
if (!hero) {
  throw new Error("No hero found for testimonialsPage. Seed: npx sanity exec scripts/seed-page-heroes.ts --with-user-token");
}
---

<Layout
  title="Testimonials"
  description="Our clients have shared what representation at the highest level meant to them. Read testimonials from those Dan Cogdell and the Cogdell Law Firm have defended."
>
  <PageHero
    eyebrow={hero.eyebrow}
    titleLead={hero.titleLead}
    titleStrong={hero.titleStrong}
    lede={hero.lede ?? ""}
    image={heroImage}
    imageAlt="The attorneys of Cogdell Law Firm ascending the courthouse steps"
    imagePosition="center 35%"
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <TestimonialsWall />
  <PracticeAreas band={practiceAreas} background="card" />
  <CtaBar pageId="testimonialsPage" />
  <Consult />
</Layout>
