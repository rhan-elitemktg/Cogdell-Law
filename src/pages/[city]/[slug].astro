---
// "Areas We Serve" location pages at /{city}/{slug}. Same format as practice
// leaf pages (Breadcrumb → hero → body → optional FAQs → CTA).
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/practice/Breadcrumb.astro";
import PageHero from "../../components/PageHero.astro";
import ProseBody from "../../components/prose/ProseBody.astro";
import PracticeFaqs from "../../components/practice/PracticeFaqs.astro";
import CtaBar from "../../components/CtaBar.astro";
import Consult from "../../components/Consult.astro";
import { getAreaPaths } from "../../sanity/lib/areasWeServe";

export async function getStaticPaths() {
  return getAreaPaths();
}

const { page, cityName, trail } = Astro.props;

const description = page.lede ?? `${page.title} — Cogdell Law Firm.`;

// The lede is its own field (meta description + card summary) and also opens the
// body, exactly as before the intro/sections merge.
const ledeBlock = page.lede
  ? [{ _type: "block", _key: "lede", style: "normal", markDefs: [], children: [{ _type: "span", _key: "ledes", text: page.lede, marks: [] }] }]
  : [];
const bodyValue = [...ledeBlock, ...(page.body ?? [])];
---

<Layout title={page.title} description={description}>
  <Breadcrumb trail={trail} />

  <PageHero
    eyebrow={`Serving ${cityName}`}
    titleStrong={page.heroTitle}
    align="center"
    contentMaxWidth="700px"
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <ProseBody body={bodyValue} />

  {page.faqs && page.faqs.length > 0 && <PracticeFaqs faqs={page.faqs} />}

  <CtaBar />
  <Consult />
</Layout>
