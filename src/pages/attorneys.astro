---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import Attorneys from "../components/Attorneys.astro";
import Testimonials from "../components/Testimonials.astro";
import WhyChoose from "../components/WhyChoose.astro";
import Consult from "../components/Consult.astro";
import heroImage from "../assets/about-courthouse.jpg";
---

<Layout
  title="Our Attorneys"
  description="Since 1988, Cogdell Law Firm's trial lawyers have brought 40+ years of experience to federal criminal charges and serious allegations across Houston, East Texas, North Texas, and the state."
>
  <PageHero
    eyebrow="Our Attorneys"
    titleLead="Tenacious Advocacy"
    titleStrong="Backed by Proven Experience."
    lede="Facing federal criminal charges or other serious allegations? We at Cogdell Law Firm are here to be your trusted allies. Since our founding in 1988, we have provided strong, unyielding advocacy. Based out of Houston, we stand up for the livelihoods of individuals in East Texas, North Texas and throughout the state. Our lawyers have over 40 years of experience to put toward your defense."
    image={heroImage}
    imageAlt="The attorneys of Cogdell Law Firm outside the courthouse"
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call 713-426-2244
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <Attorneys background="card" />
  <Testimonials />
  <WhyChoose />
  <Consult />
</Layout>
