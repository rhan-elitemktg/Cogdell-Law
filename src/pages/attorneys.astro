---
import { getPageHero } from "../sanity/lib/pageHero";
import Layout from "../layouts/Layout.astro";
import { getSeo } from "../sanity/lib/seo";
import PageHero from "../components/PageHero.astro";
import Attorneys from "../components/Attorneys.astro";
import Testimonials from "../components/Testimonials.astro";
import WhyChoose from "../components/WhyChoose.astro";
import Consult from "../components/Consult.astro";
import heroImage from "../assets/about-courthouse.jpg";
import { getAttorneysBand } from "../sanity/lib/attorneys";
import { getTestimonialsBand } from "../sanity/lib/testimonials";
import { getWhyChooseBand } from "../sanity/lib/whyChoose";

// This page holds its own copy of the band header, separate from the Home Page.
const attorneysBand = await getAttorneysBand("attorneysPage");
const testimonialsBand = await getTestimonialsBand("attorneysPage");
const whyChooseBand = await getWhyChooseBand("attorneysPage");

if (!whyChooseBand) {
  throw new Error(
    "No Why Choose band found in Sanity for this page.\n" +
      "Seed it with: npx sanity exec scripts/seed-why-choose.ts --with-user-token",
  );
}

if (!testimonialsBand) {
  throw new Error(
    "No Testimonials band found in Sanity for this page.\n" +
      "Seed it with: npx sanity exec scripts/seed-testimonials.ts --with-user-token",
  );
}

if (!attorneysBand) {
  throw new Error(
    "No Attorneys Band found on the Attorneys Page in Sanity.\n" +
      "Add it in the Studio at /admin → Attorneys Page, or seed it with:\n" +
      "  npx sanity exec scripts/seed-attorneys-band.ts --with-user-token",
  );
}

const hero = await getPageHero("attorneysPage");
if (!hero) {
  throw new Error("No hero found for attorneysPage. Seed: npx sanity exec scripts/seed-page-heroes.ts --with-user-token");
}

const seo = await getSeo("attorneysPage");
---

<Layout
  seo={seo}
  title="Our Attorneys"
  description="Since 1988, Cogdell Law Firm's trial lawyers have brought 40+ years of experience to federal criminal charges and serious allegations across Houston, East Texas, North Texas, and the state."
>
  <PageHero
    eyebrow={hero.eyebrow}
    titleLead={hero.titleLead}
    titleStrong={hero.titleStrong}
    lede={hero.lede ?? ""}
    image={heroImage}
    imageAlt="The attorneys of Cogdell Law Firm outside the courthouse"
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <Attorneys band={attorneysBand} background="card" />
  <Testimonials band={testimonialsBand} />
  <WhyChoose band={whyChooseBand} />
  <Consult />
</Layout>
