---
import Layout from "../../layouts/Layout.astro";
import AttorneyHero from "../../components/attorney/AttorneyHero.astro";
import AttorneyBio from "../../components/attorney/AttorneyBio.astro";
import Consult from "../../components/Consult.astro";
import { getAttorney, getAttorneySlugs } from "../../sanity/lib/attorneys";
import { toPlainText } from "../../lib/portableText";

// Astro hoists getStaticPaths into its own module scope, so it can't reach
// module-scope consts in this frontmatter — everything it needs is imported (F7).
export async function getStaticPaths() {
  const slugs = await getAttorneySlugs();
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const attorney = await getAttorney(slug!);

if (!attorney) {
  throw new Error(`No attorney found in Sanity for slug "${slug}".`);
}

// The meta description opens with the first line of the biography. `bio` is
// Portable Text, so flatten its first block rather than indexing a string array.
const firstBioLine = toPlainText(attorney.bio?.slice(0, 1));

const description = `${attorney.name}, ${attorney.role} at Cogdell Law Firm.${
  firstBioLine ? ` ${firstBioLine}` : ""
}`;
---

<Layout title={attorney.name} description={description} seo={attorney.seo}>
  <AttorneyHero attorney={attorney} />
  <AttorneyBio attorney={attorney} />
  <Consult />
</Layout>
