---
import Layout from "../layouts/Layout.astro";
import { getSeo } from "../sanity/lib/seo";
import PageHero from "../components/PageHero.astro";
import AboutIntro from "../components/about/AboutIntro.astro";
import SellingPoints from "../components/SellingPoints.astro";
import QuoteBand from "../components/about/QuoteBand.astro";
import FoundingAttorney from "../components/about/FoundingAttorney.astro";
import OriginStory from "../components/about/OriginStory.astro";
import Values from "../components/about/Values.astro";
import Consult from "../components/Consult.astro";
import heroImage from "../assets/about-courthouse.jpg";
import consultBoardroom from "../assets/whychoose-bg.jpg";
import { getOurFirm } from "../sanity/lib/ourFirm";

const page = await getOurFirm();
if (!page?.hero) {
  throw new Error(
    "No Our Firm page content found in Sanity.\n" +
      "Seed it with: npx sanity exec scripts/seed-our-firm.ts --with-user-token",
  );
}

const seo = await getSeo("ourFirmPage");
---

<Layout
  seo={seo}
  title="About the Firm"
  description="For more than four decades, Cogdell Law Firm has defended the cases others call unwinnable. Learn about founding attorney Dan Cogdell and our trial team."
>
  <PageHero
    eyebrow={page.hero.eyebrow}
    titleLead={page.hero.titleLead}
    titleStrong={page.hero.titleStrong}
    lede={page.hero.lede}
    image={heroImage}
    imageAlt="Dan Cogdell outside the courthouse"
  >
    <a href="#contact" class="btn btn--primary">
      Schedule Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="/attorneys" class="btn btn--outline">
      Meet Our Attorneys
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <AboutIntro
    eyebrow={page.intro.eyebrow}
    headingLead={page.intro.headingLead}
    headingStrong={page.intro.headingStrong}
    body={page.intro.body}
  />
  <SellingPoints points={page.stats.items} />
  <QuoteBand lead={page.quote.lead} accent={page.quote.accent} attribution={page.quote.attribution} />
  <FoundingAttorney
    eyebrow={page.foundingAttorney.eyebrow}
    headingLead={page.foundingAttorney.headingLead}
    headingStrong={page.foundingAttorney.headingStrong}
    body={page.foundingAttorney.body}
  />
  <OriginStory
    eyebrow={page.originStory.eyebrow}
    headingLead={page.originStory.headingLead}
    headingStrong={page.originStory.headingStrong}
    body={page.originStory.body}
    milestones={page.originStory.milestones}
  />
  <Values
    eyebrow={page.values.eyebrow}
    headingLead={page.values.headingLead}
    headingStrong={page.values.headingStrong}
    items={page.values.items}
  />
  <Consult photo={consultBoardroom} photoAlt="The Cogdell Law Firm team in the boardroom" />
</Layout>
