---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import ContactMethods from "../components/ContactMethods.astro";
import Consult from "../components/Consult.astro";
import boardroom from "../assets/whychoose-bg.jpg";
import heroImage from "../assets/firm-steps.jpg";
---

<Layout
  title="Contact"
  description="Facing federal charges, a government investigation, or a complex civil dispute? Reach Cogdell Law Firm in Houston — the first step is a confidential conversation."
>
  <PageHero
    eyebrow="Get in Touch"
    titleLead="Connect"
    titleStrong="With Us."
    image={heroImage}
    lede="Whether you're facing federal charges, a government investigation, or a complex civil dispute — the first step is a confidential conversation."
  />

  <ContactMethods />

  <Consult pageId="contactPage" photo={boardroom} photoAlt="The Cogdell Law Firm team in the boardroom" />
</Layout>
