---
import Layout from "../layouts/Layout.astro";
import ProseBody from "../components/prose/ProseBody.astro";
import { getLegalPage } from "../sanity/lib/legalPages";

const page = await getLegalPage("disclaimer");
if (!page) {
  throw new Error(
    "No Disclaimer found in Sanity.\n" +
      "Seed it with: npx sanity exec scripts/seed-legal-pages.ts --with-user-token",
  );
}
---

<Layout
  title="Disclaimer"
  description="Information on this website is not legal advice, and contacting Cogdell Law Firm does not create an attorney-client relationship."
>
  <ProseBody title={page.title} intro={page.intro} sections={page.sections} />
</Layout>
