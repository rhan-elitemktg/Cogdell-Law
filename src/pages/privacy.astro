---
import Layout from "../layouts/Layout.astro";
import ProseBody from "../components/prose/ProseBody.astro";
import { getLegalPage } from "../sanity/lib/legalPages";

const page = await getLegalPage("privacy");
if (!page) {
  throw new Error(
    "No Privacy Policy found in Sanity.\n" +
      "Seed it with: npx sanity exec scripts/seed-legal-pages.ts --with-user-token",
  );
}
---

<Layout
  title="Privacy Policy"
  description="How Cogdell Law Firm collects, uses, and protects information on this website."
  seo={page.seo}
>
  <ProseBody title={page.title} body={page.body} />
</Layout>
