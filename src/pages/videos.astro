---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import VideoGrid from "../components/video/VideoGrid.astro";
import CtaBar from "../components/CtaBar.astro";
import Consult from "../components/Consult.astro";
import { videos } from "../data/videos";
import heroImage from "../assets/firm-steps.jpg";
---

<Layout
  title="Videos"
  description="Watch Dan Cogdell and the Cogdell Law Firm — the firm film, landmark cases, and perspective from four decades in the courtroom."
  videoEmbed
>
  <PageHero
    eyebrow="Videos"
    titleLead="The Firm,"
    titleStrong="On the Record."
    image={heroImage}
    lede="A closer look at Dan Cogdell and the firm — the work, the landmark cases, and four decades of courtroom experience, in their own words."
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <VideoGrid
    items={videos}
    eyebrow="Watch"
    headingLead="From the"
    headingStrong="Firm."
  />

  <CtaBar />
  <Consult />
</Layout>
