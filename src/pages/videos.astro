---
import { getPageHero } from "../sanity/lib/pageHero";
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import VideoGrid from "../components/video/VideoGrid.astro";
import CtaBar from "../components/CtaBar.astro";
import Consult from "../components/Consult.astro";
import { getVideos, getVideoGridHeader } from "../sanity/lib/videos";
import heroImage from "../assets/firm-steps.jpg";

const videos = await getVideos();
const gridHeader = await getVideoGridHeader();

if (!videos.length || !gridHeader) {
  throw new Error(
    "No videos or grid header found in Sanity.\n" +
      "Seed with: npx sanity exec scripts/seed-hero.ts --with-user-token\n" +
      "           npx sanity exec scripts/seed-videos-page.ts --with-user-token",
  );
}

const hero = await getPageHero("videosPage");
if (!hero) {
  throw new Error("No hero found for videosPage. Seed: npx sanity exec scripts/seed-page-heroes.ts --with-user-token");
}
---

<Layout
  title="Videos"
  description="Watch Dan Cogdell and the Cogdell Law Firm — the firm film, landmark cases, and perspective from four decades in the courtroom."
  videoEmbed
>
  <PageHero
    eyebrow={hero.eyebrow}
    titleLead={hero.titleLead}
    titleStrong={hero.titleStrong}
    image={heroImage}
    lede={hero.lede ?? ""}
  >
    <a href="#contact" class="btn btn--primary">
      Schedule a Consultation
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
    <a href="tel:7134262244" class="btn btn--outline">
      Call Us Today
      <svg class="btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>
  </PageHero>

  <VideoGrid
    items={videos}
    eyebrow={gridHeader.eyebrow}
    headingLead={gridHeader.headingLead}
    headingStrong={gridHeader.headingStrong}
  />

  <CtaBar />
  <Consult />
</Layout>
